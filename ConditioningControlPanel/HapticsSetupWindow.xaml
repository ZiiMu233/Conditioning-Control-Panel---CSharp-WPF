<Window x:Class="ConditioningControlPanel.HapticsSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="触觉反馈设置指南" Height="700" Width="450"
        WindowStartupLocation="CenterOwner"
        Background="#1A1A2E" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True">

    <Border CornerRadius="12" Background="#1A1A2E" BorderBrush="#9B59B6" BorderThickness="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 头部 -->
            <Grid Grid.Row="0" Background="#252542" Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Margin="15,10">
                    <TextBlock x:Name="TxtTitle" Text="触觉反馈设置指南"
                               Foreground="#FF69B4" FontSize="18" FontWeight="Bold"/>
                </StackPanel>
                <Button Grid.Column="1" Content="X" Width="30" Height="30"
                        Background="Transparent" Foreground="#808080"
                        BorderThickness="0" FontSize="14" Cursor="Hand"
                        Click="BtnClose_Click" Margin="0,5,10,5"/>
            </Grid>

            <!-- 内容区域 -->
            <Grid Grid.Row="1" Margin="20">

                <!-- 设备类型选择（初始界面） -->
                <Grid x:Name="ProviderSelectionGrid" Visibility="Visible">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="选择您的设备类型：" Foreground="White"
                                   FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                        <Button x:Name="BtnSelectLovense" Width="280" Height="80"
                                Background="#2D2D4A" BorderBrush="#FF69B4" BorderThickness="2"
                                Cursor="Hand" Click="BtnSelectLovense_Click" Margin="0,10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Lovense" Foreground="#FF69B4" FontSize="20"
                                           FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Text=" 连接" Foreground="White" FontSize="20"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="BtnSelectButtplug" Width="280" Height="80"
                                Background="#2D2D4A" BorderBrush="#9B59B6" BorderThickness="2"
                                Cursor="Hand" Click="BtnSelectButtplug_Click" Margin="0,10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Buttplug.io" Foreground="#9B59B6" FontSize="20"
                                           FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Text=" (Intiface)" Foreground="White" FontSize="18"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Lovense 教程幻灯片 -->
                <Grid x:Name="LovenseSlides" Visibility="Collapsed">
                    <!-- 幻灯片 1：发现 + 游戏模式 -->
                    <Grid x:Name="LovenseSlide1" Visibility="Visible">
                        <StackPanel>
                            <Border Background="#FF69B4" CornerRadius="4" Padding="8,4"
                                    HorizontalAlignment="Left" Margin="0,0,0,10">
                                <TextBlock Text="第 1 步" Foreground="White" FontWeight="Bold" FontSize="12"/>
                            </Border>
                            <TextBlock Text="打开 Lovense Remote 应用" Foreground="White"
                                       FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#B0B0B0" FontSize="13" Margin="0,0,0,15">
                                <Run>1. 在手机上打开 </Run>
                                <Run Foreground="#FF69B4" FontWeight="Bold">Lovense Remote</Run>
                                <Run> 应用</Run>
                                <LineBreak/>
                                <Run>2. 点击底部 </Run>
                                <Run Foreground="#FF69B4" FontWeight="Bold">Discover</Run>
                                <LineBreak/>
                                <Run>3. 找到并点击 </Run>
                                <Run Foreground="#FF69B4" FontWeight="Bold">Game Mode</Run>
                            </TextBlock>
                            <Border Background="#2D2D4A" CornerRadius="8" Padding="10" MaxHeight="400">
                                <Image x:Name="ImgLovenseStep1" Stretch="Uniform"
                                       Source="Resources/haptics_guide/lovense_step1.png"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- 幻灯片 2：启用局域网 -->
                    <Grid x:Name="LovenseSlide2" Visibility="Collapsed">
                        <StackPanel>
                            <Border Background="#FF69B4" CornerRadius="4" Padding="8,4"
                                    HorizontalAlignment="Left" Margin="0,0,0,10">
                                <TextBlock Text="第 2 步" Foreground="White" FontWeight="Bold" FontSize="12"/>
                            </Border>
                            <TextBlock Text="启用局域网连接" Foreground="White"
                                       FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#B0B0B0" FontSize="13" Margin="0,0,0,15">
                                <Run>1. 将 </Run>
                                <Run Foreground="#FF69B4" FontWeight="Bold">Enable LAN</Run>
                                <Run> 开关打开</Run>
                                <LineBreak/>
                                <Run>2. 记下显示的 </Run>
                                <Run Foreground="#FF69B4" FontWeight="Bold">Local IP</Run>
                                <Run> 地址</Run>
                                <LineBreak/>
                                <Run>3. 记下 </Run>
                                <Run Foreground="#FF69B4" FontWeight="Bold">Port</Run>
                                <Run> 端口号（通常为 20010）</Run>
                            </TextBlock>
                            <Border Background="#2D2D4A" CornerRadius="8" Padding="10" MaxHeight="400">
                                <Image x:Name="ImgLovenseStep2" Stretch="Uniform"
                                       Source="Resources/haptics_guide/lovense_step2.png"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- 幻灯片 3：输入 URL -->
                    <Grid x:Name="LovenseSlide3" Visibility="Collapsed">
                        <StackPanel VerticalAlignment="Center">
                            <Border Background="#FF69B4" CornerRadius="4" Padding="8,4"
                                    HorizontalAlignment="Left" Margin="0,0,0,10">
                                <TextBlock Text="第 3 步" Foreground="White" FontWeight="Bold" FontSize="12"/>
                            </Border>
                            <TextBlock Text="输入连接地址" Foreground="White"
                                       FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                            <Border Background="#2D2D4A" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock Text="在条件控制面板中：" Foreground="White"
                                               FontSize="14" Margin="0,0,0,15"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="#B0B0B0" FontSize="13">
                                        <Run>1. 选择 </Run>
                                        <Run Foreground="#FF69B4" FontWeight="Bold">Lovense Connect</Run>
                                        <Run> 作为提供程序</Run>
                                        <LineBreak/><LineBreak/>
                                        <Run>2. 按照以下格式输入地址：</Run>
                                    </TextBlock>

                                    <Border Background="#1A1A2E" CornerRadius="4" Padding="12" Margin="0,10,0,10">
                                        <TextBlock Text="http://[IP]:[端口]" Foreground="#FF69B4"
                                                   FontSize="16" FontWeight="Bold" FontFamily="Consolas"
                                                   HorizontalAlignment="Center"/>
                                    </Border>

                                    <TextBlock Text="示例：" Foreground="#808080" FontSize="12" Margin="0,5,0,5"/>
                                    <Border Background="#1A1A2E" CornerRadius="4" Padding="10">
                                        <TextBlock Text="http://192.168.1.104:20010" Foreground="#00FF00"
                                                   FontSize="14" FontFamily="Consolas"
                                                   HorizontalAlignment="Center"/>
                                    </Border>

                                    <TextBlock TextWrapping="Wrap" Foreground="#B0B0B0" FontSize="13" Margin="0,15,0,0">
                                        <Run>3. 点击 </Run>
                                        <Run Foreground="#FF69B4" FontWeight="Bold">连接</Run>
                                        <LineBreak/><LineBreak/>
                                        <Run Foreground="#FFD700">提示：确保手机和电脑连接到同一个 WiFi 网络！</Run>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- Buttplug.io 教程幻灯片 -->
                <Grid x:Name="ButtplugSlides" Visibility="Collapsed">
                    <!-- 幻灯片 1：启动引擎 -->
                    <Grid x:Name="ButtplugSlide1" Visibility="Visible">
                        <StackPanel>
                            <Border Background="#9B59B6" CornerRadius="4" Padding="8,4"
                                    HorizontalAlignment="Left" Margin="0,0,0,10">
                                <TextBlock Text="第 1 步" Foreground="White" FontWeight="Bold" FontSize="12"/>
                            </Border>
                            <TextBlock Text="启动 Intiface Central" Foreground="White"
                                       FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#B0B0B0" FontSize="13" Margin="0,0,0,15">
                                <Run>1. 下载并安装 </Run>
                                <Run Foreground="#9B59B6" FontWeight="Bold">Intiface Central</Run>
                                <LineBreak/>
                                <Run>2. 点击 </Run>
                                <Run Foreground="#9B59B6" FontWeight="Bold">Start Server</Run>
                                <Run> 启动服务引擎</Run>
                                <LineBreak/>
                                <Run>3. 点击 </Run>
                                <Run Foreground="#9B59B6" FontWeight="Bold">Start Scanning</Run>
                                <Run> 搜索设备</Run>
                            </TextBlock>
                            <Border Background="#2D2D4A" CornerRadius="8" Padding="10" MaxHeight="400">
                                <Image x:Name="ImgButtplugStep1" Stretch="Uniform"
                                       Source="Resources/haptics_guide/buttplug_step1.png"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- 幻灯片 2：连接设备 -->
                    <Grid x:Name="ButtplugSlide2" Visibility="Collapsed">
                        <StackPanel>
                            <Border Background="#9B59B6" CornerRadius="4" Padding="8,4"
                                    HorizontalAlignment="Left" Margin="0,0,0,10">
                                <TextBlock Text="第 2 步" Foreground="White" FontWeight="Bold" FontSize="12"/>
                            </Border>
                            <TextBlock Text="连接您的设备" Foreground="White"
                                       FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#B0B0B0" FontSize="13" Margin="0,0,0,15">
                                <Run>1. 将设备置于 </Run>
                                <Run Foreground="#9B59B6" FontWeight="Bold">配对模式</Run>
                                <LineBreak/>
                                <Run>2. 等待设备出现在 </Run>
                                <Run Foreground="#9B59B6" FontWeight="Bold">Devices</Run>
                                <Run> 列表中</Run>
                                <LineBreak/>
                                <Run>3. 设备应显示为 </Run>
                                <Run Foreground="#00FF00">已连接</Run>
                            </TextBlock>
                            <Border Background="#2D2D4A" CornerRadius="8" Padding="10" MaxHeight="400">
                                <Image x:Name="ImgButtplugStep2" Stretch="Uniform"
                                       Source="Resources/haptics_guide/buttplug_step2.png"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- 幻灯片 3：输入 URL -->
                    <Grid x:Name="ButtplugSlide3" Visibility="Collapsed">
                        <StackPanel VerticalAlignment="Center">
                            <Border Background="#9B59B6" CornerRadius="4" Padding="8,4"
                                    HorizontalAlignment="Left" Margin="0,0,0,10">
                                <TextBlock Text="第 3 步" Foreground="White" FontWeight="Bold" FontSize="12"/>
                            </Border>
                            <TextBlock Text="输入连接地址" Foreground="White"
                                       FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                            <Border Background="#2D2D4A" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock Text="在条件控制面板中：" Foreground="White"
                                               FontSize="14" Margin="0,0,0,15"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="#B0B0B0" FontSize="13">
                                        <Run>1. 选择 </Run>
                                        <Run Foreground="#9B59B6" FontWeight="Bold">Buttplug.io (Intiface)</Run>
                                        <Run> 作为提供程序</Run>
                                        <LineBreak/><LineBreak/>
                                        <Run>2. 输入默认地址：</Run>
                                    </TextBlock>

                                    <Border Background="#1A1A2E" CornerRadius="4" Padding="12" Margin="0,10,0,10">
                                        <TextBlock Text="ws://localhost:12345" Foreground="#9B59B6"
                                                   FontSize="16" FontWeight="Bold" FontFamily="Consolas"
                                                   HorizontalAlignment="Center"/>
                                    </Border>

                                    <TextBlock TextWrapping="Wrap" Foreground="#B0B0B0" FontSize="13" Margin="0,10,0,0">
                                        <Run Foreground="#808080">这是 Intiface 服务器的默认地址。</Run>
                                        <LineBreak/>
                                        <Run Foreground="#808080">仅当您修改了 Intiface 中的设置时才需要更改。</Run>
                                    </TextBlock>

                                    <TextBlock TextWrapping="Wrap" Foreground="#B0B0B0" FontSize="13" Margin="0,15,0,0">
                                        <Run>3. 点击 </Run>
                                        <Run Foreground="#9B59B6" FontWeight="Bold">连接</Run>
                                        <LineBreak/><LineBreak/>
                                        <Run Foreground="#FFD700">提示：连接前请确保 Intiface Central 正在运行！</Run>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>

            <!-- 导航底部栏 -->
            <Grid Grid.Row="2" Background="#252542" Margin="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnPrevious" Content="上一步"
                        Grid.Column="0" HorizontalAlignment="Left"
                        Background="#353555" Foreground="White"
                        BorderThickness="0" Padding="20,10" Margin="15,10"
                        FontSize="13" Cursor="Hand" Visibility="Collapsed"
                        Click="BtnPrevious_Click"/>

                <StackPanel x:Name="SlideIndicators" Grid.Column="1"
                            Orientation="Horizontal" HorizontalAlignment="Center"
                            VerticalAlignment="Center" Visibility="Collapsed">
                    <Ellipse x:Name="Dot1" Width="10" Height="10" Fill="#FF69B4" Margin="5,0"/>
                    <Ellipse x:Name="Dot2" Width="10" Height="10" Fill="#404060" Margin="5,0"/>
                    <Ellipse x:Name="Dot3" Width="10" Height="10" Fill="#404060" Margin="5,0"/>
                </StackPanel>

                <Button x:Name="BtnNext" Content="下一步"
                        Grid.Column="2" HorizontalAlignment="Right"
                        Background="#FF69B4" Foreground="White"
                        BorderThickness="0" Padding="20,10" Margin="15,10"
                        FontSize="13" Cursor="Hand" Visibility="Collapsed"
                        Click="BtnNext_Click"/>

                <Button x:Name="BtnDone" Content="完成"
                        Grid.Column="2" HorizontalAlignment="Right"
                        Background="#00AA00" Foreground="White"
                        BorderThickness="0" Padding="20,10" Margin="15,10"
                        FontSize="13" Cursor="Hand" Visibility="Collapsed"
                        Click="BtnClose_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
