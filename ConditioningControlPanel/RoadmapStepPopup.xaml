以下是汉化后的 `RoadmapStepPopup.xaml` 代码：

```xml
<Window x:Class="ConditioningControlPanel.RoadmapStepPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="步骤完成！"
        Width="400" Height="180"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Background="#E01A1A2E" CornerRadius="12" BorderBrush="{StaticResource PinkBrush}" BorderThickness="2"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="#FF69B4" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
        </Border.Effect>

        <Grid Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 步骤照片/图标 -->
            <Border Grid.Column="0" Width="100" Height="100" Background="#1A1A2E"
                    CornerRadius="50" Margin="0,0,15,0" ClipToBounds="True">
                <Grid>
                    <!-- 照片缩略图（如有） -->
                    <Ellipse x:Name="PhotoEllipse" Width="96" Height="96" Visibility="Collapsed">
                        <Ellipse.Fill>
                            <ImageBrush x:Name="PhotoBrush" Stretch="UniformToFill"/>
                        </Ellipse.Fill>
                    </Ellipse>
                    <!-- 默认对勾图标 -->
                    <TextBlock x:Name="CheckmarkIcon" Text="✓" FontSize="48" FontWeight="Bold"
                               Foreground="#00E676" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- 文本内容 -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <!-- 星星图标 + "步骤完成" -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="✨" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="步骤完成！" Foreground="#FFD700"
                               FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 步骤标题 -->
                <TextBlock x:Name="TxtStepTitle" Text="步骤标题"
                           Foreground="{StaticResource PinkBrush}"
                           FontWeight="Bold" FontSize="18"
                           TextWrapping="Wrap" Margin="0,0,0,8"/>

                <!-- 轨道名称 -->
                <TextBlock x:Name="TxtTrackName" Text="轨道名称"
                           Foreground="#AAAAAA" FontSize="12"
                           TextWrapping="Wrap" FontStyle="Italic"/>
            </StackPanel>

            <!-- 关闭按钮 -->
            <Button Grid.Column="1" Content="✕"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Width="24" Height="24" Margin="0,-5,-5,0"
                    Background="Transparent" Foreground="#888888"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnClose_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Border>
</Window>
```
