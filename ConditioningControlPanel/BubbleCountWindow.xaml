<Window x:Class="ConditioningControlPanel.BubbleCountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="泡泡计数挑战"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Black"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="True"
        ResizeMode="NoResize"
        FontFamily="Comic Sans MS, Segoe UI">

    <Grid x:Name="MainGrid">
        <!-- Video Player Container - VideoView added programmatically -->
        <!-- Bubbles are now separate windows to avoid blocking LibVLC rendering -->
        <Grid x:Name="VideoContainer" Background="Black"/>

        <!-- 顶部信息栏 -->
        <Border Background="#80000000"
                VerticalAlignment="Top"
                Padding="20,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="🫧 数泡泡！🫧"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="#FF69B4">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#FF69B4" BlurRadius="10" ShadowDepth="0" Opacity="0.6"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock x:Name="TxtDifficulty"
                           Text="（中等）"
                           FontSize="22"
                           Foreground="#FFB6C1"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- 严格模式提示 -->
        <TextBlock x:Name="TxtStrict"
                   Text="🔒 严格模式"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="#FF6B6B"
                   VerticalAlignment="Top"
                   HorizontalAlignment="Right"
                   Margin="0,15,20,0"
                   Visibility="Collapsed"/>

        <!-- ESC 提示 -->
        <TextBlock x:Name="TxtEscHint"
                   Text="按 ESC 跳过（不会获得经验值）"
                   FontSize="16"
                   Foreground="#888888"
                   VerticalAlignment="Bottom"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>
    </Grid>
</Window>
