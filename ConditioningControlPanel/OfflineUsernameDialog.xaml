以下是汉化后的 `OfflineUsernameDialog.xaml` 代码：

```xml
<Window x:Class="ConditioningControlPanel.OfflineUsernameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择离线用户名"
        Height="300" Width="450"
        WindowStartupLocation="CenterOwner"
        Background="#1A1A2E"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="False">

    <Window.Resources>
        <SolidColorBrush x:Key="PinkBrush" Color="#FF69B4"/>
        <SolidColorBrush x:Key="DarkPinkBrush" Color="#FF1493"/>
        <SolidColorBrush x:Key="InfoBrush" Color="#88AAFF"/>
    </Window.Resources>

    <Border BorderBrush="{StaticResource PinkBrush}" BorderThickness="1" CornerRadius="0">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题 -->
            <TextBlock Grid.Row="0" Text="选择离线用户名"
                       Foreground="{StaticResource PinkBrush}"
                       FontSize="18" FontWeight="Bold" Margin="0,0,0,10"
                       HorizontalAlignment="Center"/>

            <!-- 信息框 -->
            <Border Grid.Row="1" Background="#2A2A3E" CornerRadius="4" Padding="12,8" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="离线进度仅存储在本地，无法同步到排行榜。"
                               Foreground="{StaticResource InfoBrush}"
                               FontSize="12" TextWrapping="Wrap" TextAlignment="Center"/>
                    <TextBlock Text="您可以在设置中稍后更改此名称。"
                               Foreground="#888888"
                               FontSize="11" Margin="0,5,0,0" TextAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- 提示 -->
            <TextBlock Grid.Row="2" Text="请输入您希望使用的名称："
                       Foreground="White" FontSize="13" Margin="0,0,0,8"/>

            <!-- 输入框 -->
            <TextBox x:Name="TxtUsername" Grid.Row="3"
                     Background="#252542" Foreground="White"
                     BorderBrush="{StaticResource PinkBrush}"
                     Padding="12,10" FontSize="15"
                     MaxLength="30"
                     KeyDown="TxtUsername_KeyDown"/>

            <!-- 字符计数 -->
            <TextBlock x:Name="TxtCharCount" Grid.Row="4" Text="0/30 字符"
                       Foreground="#888" FontSize="11" Margin="0,5,0,0"
                       HorizontalAlignment="Right" VerticalAlignment="Top"/>

            <!-- 按钮 -->
            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="取消" Width="90" Padding="10,10" Margin="0,0,10,0"
                        Background="#555577" Foreground="White" BorderThickness="0"
                        Click="BtnCancel_Click" Cursor="Hand" FontSize="13" FontWeight="SemiBold"/>
                <Button x:Name="BtnConfirm" Content="确认" Width="90" Padding="10,10"
                        Background="{StaticResource PinkBrush}" Foreground="White"
                        BorderThickness="0" FontWeight="Bold" FontSize="13"
                        Click="BtnConfirm_Click" Cursor="Hand" IsEnabled="False"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
```
