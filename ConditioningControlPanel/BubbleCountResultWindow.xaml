<Window x:Class="ConditioningControlPanel.BubbleCountResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="有多少个泡泡？"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowState="Maximized"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        FontFamily="Comic Sans MS, Segoe UI">
    
    <Grid>
        <!-- 半透明背景 -->
        <Rectangle Fill="#E0000000"/>
        
        <!-- 内容卡片 -->
        <Border Background="#FF2D2D3A"
                CornerRadius="20"
                Padding="50"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MinWidth="500"
                MaxWidth="600">
            <Border.Effect>
                <DropShadowEffect Color="#FF69B4" BlurRadius="30" ShadowDepth="0" Opacity="0.5"/>
            </Border.Effect>
            
            <StackPanel>
                <!-- 标题 -->
                <TextBlock Text="🫧 有多少个泡泡？ 🫧"
                           FontSize="40"
                           FontWeight="Bold"
                           Foreground="#FF69B4"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#FF69B4" BlurRadius="12" ShadowDepth="0" Opacity="0.6"/>
                    </TextBlock.Effect>
                </TextBlock>
                
                <!-- 说明 -->
                <TextBlock Text="请输入你数到的泡泡数量："
                           FontSize="18"
                           Foreground="#FFB6C1"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>
                
                <!-- 数字输入框 -->
                <TextBox x:Name="TxtAnswer"
                         FontSize="48"
                         FontWeight="Bold"
                         Foreground="White"
                         Background="#40FFFFFF"
                         BorderBrush="#FF69B4"
                         BorderThickness="3"
                         Padding="20,10"
                         HorizontalAlignment="Center"
                         MinWidth="200"
                         TextAlignment="Center"
                         MaxLength="3"/>
                
                <!-- 剩余尝试次数 -->
                <TextBlock x:Name="TxtAttempts"
                           Text="剩余尝试次数：3"
                           FontSize="16"
                           Foreground="#888888"
                           HorizontalAlignment="Center"
                           Margin="0,20,0,0"/>
                
                <!-- 反馈信息 -->
                <TextBlock x:Name="TxtFeedback"
                           Text=""
                           FontSize="20"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,15,0,0"
                           Visibility="Collapsed"/>
                
                <!-- 提交按钮 -->
                <Button x:Name="BtnSubmit"
                        Content="✓ 提交"
                        FontSize="24"
                        FontWeight="Bold"
                        Foreground="White"
                        Background="#FF69B4"
                        BorderThickness="0"
                        Padding="40,15"
                        Margin="0,30,0,0"
                        Cursor="Hand"
                        HorizontalAlignment="Center"
                        Click="BtnSubmit_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="10"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                
                <!-- 严格模式提示 -->
                <TextBlock x:Name="TxtStrict"
                           Text="🔒 严格模式 - 必须回答正确"
                           FontSize="14"
                           Foreground="#FF6B6B"
                           HorizontalAlignment="Center"
                           Margin="0,20,0,0"
                           Visibility="Collapsed"/>
                
                <!-- ESC 提示 -->
                <TextBlock x:Name="TxtEscHint"
                           Text="按 ESC 跳过（不会获得经验值）"
                           FontSize="12"
                           Foreground="#666666"
                           HorizontalAlignment="Center"
                           Margin="0,15,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
