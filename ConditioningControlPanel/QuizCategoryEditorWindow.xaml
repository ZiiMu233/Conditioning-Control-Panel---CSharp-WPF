<Window x:Class="ConditioningControlPanel.QuizCategoryEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Custom Quiz Category"
        Width="700" Height="750"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        KeyDown="Window_KeyDown">

    <Border CornerRadius="16" Margin="8">
        <Border.Background>
            <SolidColorBrush Color="#F0151530"/>
        </Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#60FF69B4" Offset="0"/>
                <GradientStop Color="#609B59B6" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.BorderThickness>
            <Thickness>1.5</Thickness>
        </Border.BorderThickness>
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0" Opacity="0.6"/>
        </Border.Effect>

        <Grid Margin="28,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <Grid>
                    <TextBlock x:Name="TxtTitle" Text="CREATE CUSTOM CATEGORY" FontSize="22" FontWeight="Bold"
                               Foreground="#FF69B4" HorizontalAlignment="Left">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#FF69B4" BlurRadius="15" ShadowDepth="0" Opacity="0.3"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <!-- Close button -->
                    <TextBlock Text="X" FontSize="18" FontWeight="Bold" Foreground="#606080"
                               HorizontalAlignment="Right" VerticalAlignment="Top" Cursor="Hand"
                               MouseLeftButtonDown="BtnClose_Click"
                               MouseEnter="CloseBtn_MouseEnter" MouseLeave="CloseBtn_MouseLeave"/>
                </Grid>
                <TextBlock Text="Design your own quiz theme with custom archetypes and AI prompt"
                           Foreground="#606080" FontSize="13" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Scrollable content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled" Margin="0,0,-8,0" Padding="0,0,8,0">
                <StackPanel>
                    <!-- Category Name -->
                    <TextBlock Text="CATEGORY NAME" Foreground="#808090" FontSize="11" FontWeight="Bold"
                               Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtName" MaxLength="30" FontSize="15" Foreground="White"
                             Background="#20FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1"
                             Padding="10,8" CaretBrush="White">
                        <TextBox.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                        </TextBox.Resources>
                    </TextBox>

                    <!-- Description -->
                    <TextBlock Text="DESCRIPTION" Foreground="#808090" FontSize="11" FontWeight="Bold"
                               Margin="0,14,0,4"/>
                    <TextBox x:Name="TxtDescription" MaxLength="200" FontSize="13" Foreground="White"
                             Background="#20FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1"
                             Padding="10,8" CaretBrush="White" TextWrapping="Wrap"
                             AcceptsReturn="False" Height="50">
                        <TextBox.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                        </TextBox.Resources>
                    </TextBox>

                    <!-- Color picker -->
                    <TextBlock Text="ACCENT COLOR" Foreground="#808090" FontSize="11" FontWeight="Bold"
                               Margin="0,14,0,6"/>
                    <WrapPanel x:Name="ColorPicker" Orientation="Horizontal"/>

                    <!-- Template dropdown -->
                    <TextBlock Text="START FROM TEMPLATE" Foreground="#808090" FontSize="11" FontWeight="Bold"
                               Margin="0,14,0,4"/>
                    <ComboBox x:Name="CboTemplate" FontSize="13" Foreground="White"
                              Background="#20FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1"
                              Padding="8,6" SelectionChanged="CboTemplate_SelectionChanged">
                        <ComboBox.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#1A1A2E"/>
                        </ComboBox.Resources>
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Background" Value="#1A1A2E"/>
                                <Setter Property="Padding" Value="8,6"/>
                                <Style.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter Property="Background" Value="#30FF69B4"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                        <ComboBoxItem Content="Blank (write your own)" Tag="" IsSelected="True"/>
                        <ComboBoxItem Content="Copy from: Sissy" Tag="sissy"/>
                        <ComboBoxItem Content="Copy from: Bambi" Tag="bambi"/>
                        <ComboBoxItem Content="Copy from: Obedience" Tag="obedience"/>
                        <ComboBoxItem Content="Copy from: Mindlessness" Tag="mindlessness"/>
                        <ComboBoxItem Content="Copy from: Submission" Tag="submission"/>
                    </ComboBox>

                    <!-- System prompt -->
                    <TextBlock Text="SYSTEM PROMPT" Foreground="#808090" FontSize="11" FontWeight="Bold"
                               Margin="0,14,0,4"/>
                    <TextBlock Text="This is the AI instruction that generates quiz questions. Include tone, question themes, intensity scaling, and the answer format."
                               Foreground="#505060" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtPrompt" FontSize="12" Foreground="#C0C0D0"
                             Background="#10FFFFFF" BorderBrush="#20FFFFFF" BorderThickness="1"
                             Padding="10,8" CaretBrush="White" TextWrapping="Wrap"
                             AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                             Height="160" FontFamily="Consolas">
                        <TextBox.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                        </TextBox.Resources>
                    </TextBox>

                    <!-- Archetypes -->
                    <TextBlock Text="ARCHETYPES (5 tiers)" Foreground="#808090" FontSize="11" FontWeight="Bold"
                               Margin="0,16,0,6"/>
                    <TextBlock Text="Define the personality names assigned at each score range"
                               Foreground="#505060" FontSize="11" Margin="0,0,0,8"/>

                    <!-- Column headers -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="55"/>
                            <ColumnDefinition Width="55"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Name" Foreground="#606070" FontSize="10" Grid.Column="0" Margin="4,0,0,0"/>
                        <TextBlock Text="Min %" Foreground="#606070" FontSize="10" Grid.Column="1" Margin="4,0,0,0"/>
                        <TextBlock Text="Max %" Foreground="#606070" FontSize="10" Grid.Column="2" Margin="4,0,0,0"/>
                        <TextBlock Text="Description" Foreground="#606070" FontSize="10" Grid.Column="3" Margin="4,0,0,0"/>
                    </Grid>

                    <StackPanel x:Name="ArchetypeRows"/>

                    <!-- Preview button -->
                    <Border x:Name="BtnPreview" Cursor="Hand" CornerRadius="8" Margin="0,16,0,0"
                            Padding="12,8" HorizontalAlignment="Left"
                            MouseLeftButtonDown="BtnPreview_Click"
                            MouseEnter="ActionBtn_MouseEnter" MouseLeave="ActionBtn_MouseLeave">
                        <Border.Background>
                            <SolidColorBrush Color="#15FFFFFF"/>
                        </Border.Background>
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#309B59B6"/>
                        </Border.BorderBrush>
                        <Border.BorderThickness>
                            <Thickness>1</Thickness>
                        </Border.BorderThickness>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Preview" Foreground="#9B59B6" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock x:Name="TxtPreviewHint" Text="  — generate a sample question" Foreground="#505060" FontSize="12"/>
                        </StackPanel>
                    </Border>

                    <!-- Preview result -->
                    <Border x:Name="PreviewResultPanel" Visibility="Collapsed" CornerRadius="8"
                            Margin="0,8,0,0" Padding="12,10"
                            Background="#10FFFFFF" BorderBrush="#209B59B6" BorderThickness="1">
                        <TextBlock x:Name="TxtPreviewResult" FontSize="12" Foreground="#A0A0B0"
                                   TextWrapping="Wrap" FontFamily="Consolas"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Bottom buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,4">
                <!-- Delete button (only for editing existing) -->
                <Border x:Name="BtnDelete" Cursor="Hand" CornerRadius="8" Padding="16,10"
                        Margin="0,0,10,0" Visibility="Collapsed"
                        MouseLeftButtonDown="BtnDelete_Click"
                        MouseEnter="ActionBtn_MouseEnter" MouseLeave="ActionBtn_MouseLeave">
                    <Border.Background>
                        <SolidColorBrush Color="#15FF4444"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#30FF4444"/>
                    </Border.BorderBrush>
                    <Border.BorderThickness>
                        <Thickness>1</Thickness>
                    </Border.BorderThickness>
                    <TextBlock Text="Delete" Foreground="#FF6666" FontSize="14" FontWeight="SemiBold"/>
                </Border>

                <!-- Cancel -->
                <Border Cursor="Hand" CornerRadius="8" Padding="16,10" Margin="0,0,10,0"
                        MouseLeftButtonDown="BtnCancel_Click"
                        MouseEnter="ActionBtn_MouseEnter" MouseLeave="ActionBtn_MouseLeave">
                    <Border.Background>
                        <SolidColorBrush Color="#15FFFFFF"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#20FFFFFF"/>
                    </Border.BorderBrush>
                    <Border.BorderThickness>
                        <Thickness>1</Thickness>
                    </Border.BorderThickness>
                    <TextBlock Text="Cancel" Foreground="#808090" FontSize="14" FontWeight="SemiBold"/>
                </Border>

                <!-- Save -->
                <Border x:Name="BtnSave" Cursor="Hand" CornerRadius="8" Padding="20,10"
                        MouseLeftButtonDown="BtnSave_Click"
                        MouseEnter="ActionBtn_MouseEnter" MouseLeave="ActionBtn_MouseLeave">
                    <Border.Background>
                        <SolidColorBrush Color="#25FF69B4"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#50FF69B4"/>
                    </Border.BorderBrush>
                    <Border.BorderThickness>
                        <Thickness>1</Thickness>
                    </Border.BorderThickness>
                    <TextBlock x:Name="TxtSave" Text="Save Category" Foreground="#FF69B4"
                               FontSize="14" FontWeight="Bold"/>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</Window>
