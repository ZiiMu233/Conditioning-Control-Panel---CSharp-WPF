以下是汉化后的 `QuizCategoryEditorWindow.xaml` 代码：

```xml
<Window x:Class="ConditioningControlPanel.QuizCategoryEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="自定义测验类别"
        Width="700" Height="750"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        KeyDown="Window_KeyDown">

    <Border CornerRadius="16" Margin="8">
        <Border.Background>
            <SolidColorBrush Color="#F0151530"/>
        </Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#60FF69B4" Offset="0"/>
                <GradientStop Color="#609B59B6" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.BorderThickness>
            <Thickness>1.5</Thickness>
        </Border.BorderThickness>
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0" Opacity="0.6"/>
        </Border.Effect>

        <Grid Margin="28,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 头部 -->
            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <Grid>
                    <TextBlock x:Name="TxtTitle" Text="创建自定义类别" FontSize="22" FontWeight="Bold"
                               Foreground="#FF69B4" HorizontalAlignment="Left">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#FF69B4" BlurRadius="15" ShadowDepth="0" Opacity="0.3"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <!-- 关闭按钮 -->
                    <TextBlock Text="X" FontSize="18" FontWeight="Bold" Foreground="#606080"
                               HorizontalAlignment="Right" VerticalAlignment="Top" Cursor="Hand"
                               MouseLeftButtonDown="BtnClose_Click"
                               MouseEnter="CloseBtn_MouseEnter" MouseLeave="CloseBtn_MouseLeave"/>
                </Grid>
                <TextBlock Text="设计你自己的测验主题，包含自定义角色原型和 AI 提示词"
                           Foreground="#606080" FontSize="13" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- 滚动内容区 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled" Margin="0,0,-8,0" Padding="0,0,8,0">
                <StackPanel>
                    <!-- 类别名称 -->
                    <TextBlock Text="类别名称" Foreground="#808090" FontSize="11" FontWeight="Bold"
                               Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtName" MaxLength="30" FontSize="15" Foreground="White"
                             Background="#20FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1"
                             Padding="10,8" CaretBrush="White">
                        <TextBox.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                        </TextBox.Resources>
                    </TextBox>

                    <!-- 描述 -->
                    <TextBlock Text="描述" Foreground="#808090" FontSize="11" FontWeight="Bold"
                               Margin="0,14,0,4"/>
                    <TextBox x:Name="TxtDescription" MaxLength="200" FontSize="13" Foreground="White"
                             Background="#20FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1"
                             Padding="10,8" CaretBrush="White" TextWrapping="Wrap"
                             AcceptsReturn="False" Height="50">
                        <TextBox.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                        </TextBox.Resources>
                    </TextBox>

                    <!-- 颜色选择器 -->
                    <TextBlock Text="强调色" Foreground="#808090" FontSize="11" FontWeight="Bold"
                               Margin="0,14,0,6"/>
                    <WrapPanel x:Name="ColorPicker" Orientation="Horizontal"/>

                    <!-- 模板下拉框 -->
                    <TextBlock Text="从模板开始" Foreground="#808090" FontSize="11" FontWeight="Bold"
                               Margin="0,14,0,4"/>
                    <ComboBox x:Name="CboTemplate" FontSize="13" Foreground="White"
                              Background="#20FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1"
                              Padding="8,6" SelectionChanged="CboTemplate_SelectionChanged">
                        <ComboBox.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#1A1A2E"/>
                        </ComboBox.Resources>
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Background" Value="#1A1A2E"/>
                                <Setter Property="Padding" Value="8,6"/>
                                <Style.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter Property="Background" Value="#30FF69B4"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                        <ComboBoxItem Content="空白（自己编写）" Tag="" IsSelected="True"/>
                        <ComboBoxItem Content="复制自：Sissy" Tag="sissy"/>
                        <ComboBoxItem Content="复制自：Bambi" Tag="bambi"/>
                        <ComboBoxItem Content="复制自：Obedience" Tag="obedience"/>
                        <ComboBoxItem Content="复制自：Mindlessness" Tag="mindlessness"/>
                        <ComboBoxItem Content="复制自：Submission" Tag="submission"/>
                    </ComboBox>

                    <!-- 系统提示词 -->
                    <TextBlock Text="系统提示词" Foreground="#808090" FontSize="11" FontWeight="Bold"
                               Margin="0,14,0,4"/>
                    <TextBlock Text="这是生成测验问题的 AI 指令。包含语气、问题主题、强度变化以及答案格式。"
                               Foreground="#505060" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtPrompt" FontSize="12" Foreground="#C0C0D0"
                             Background="#10FFFFFF" BorderBrush="#20FFFFFF" BorderThickness="1"
                             Padding="10,8" CaretBrush="White" TextWrapping="Wrap"
                             AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                             Height="160" FontFamily="Consolas">
                        <TextBox.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                        </TextBox.Resources>
                    </TextBox>

                    <!-- 角色原型（5个等级） -->
                    <TextBlock Text="角色原型（5个等级）" Foreground="#808090" FontSize="11" FontWeight="Bold"
                               Margin="0,16,0,6"/>
                    <TextBlock Text="定义每个分数范围对应的角色名称"
                               Foreground="#505060" FontSize="11" Margin="0,0,0,8"/>

                    <!-- 列标题 -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="55"/>
                            <ColumnDefinition Width="55"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="名称" Foreground="#606070" FontSize="10" Grid.Column="0" Margin="4,0,0,0"/>
                        <TextBlock Text="最低%" Foreground="#606070" FontSize="10" Grid.Column="1" Margin="4,0,0,0"/>
                        <TextBlock Text="最高%" Foreground="#606070" FontSize="10" Grid.Column="2" Margin="4,0,0,0"/>
                        <TextBlock Text="描述" Foreground="#606070" FontSize="10" Grid.Column="3" Margin="4,0,0,0"/>
                    </Grid>

                    <StackPanel x:Name="ArchetypeRows"/>

                    <!-- 预览按钮 -->
                    <Border x:Name="BtnPreview" Cursor="Hand" CornerRadius="8" Margin="0,16,0,0"
                            Padding="12,8" HorizontalAlignment="Left"
                            MouseLeftButtonDown="BtnPreview_Click"
                            MouseEnter="ActionBtn_MouseEnter" MouseLeave="ActionBtn_MouseLeave">
                        <Border.Background>
                            <SolidColorBrush Color="#15FFFFFF"/>
                        </Border.Background>
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#309B59B6"/>
                        </Border.BorderBrush>
                        <Border.BorderThickness>
                            <Thickness>1</Thickness>
                        </Border.BorderThickness>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="预览" Foreground="#9B59B6" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock x:Name="TxtPreviewHint" Text=" — 生成示例问题" Foreground="#505060" FontSize="12"/>
                        </StackPanel>
                    </Border>

                    <!-- 预览结果 -->
                    <Border x:Name="PreviewResultPanel" Visibility="Collapsed" CornerRadius="8"
                            Margin="0,8,0,0" Padding="12,10"
                            Background="#10FFFFFF" BorderBrush="#209B59B6" BorderThickness="1">
                        <TextBlock x:Name="TxtPreviewResult" FontSize="12" Foreground="#A0A0B0"
                                   TextWrapping="Wrap" FontFamily="Consolas"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- 底部按钮 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,4">
                <!-- 删除按钮（仅在编辑已有类别时显示） -->
                <Border x:Name="BtnDelete" Cursor="Hand" CornerRadius="8" Padding="16,10"
                        Margin="0,0,10,0" Visibility="Collapsed"
                        MouseLeftButtonDown="BtnDelete_Click"
                        MouseEnter="ActionBtn_MouseEnter" MouseLeave="ActionBtn_MouseLeave">
                    <Border.Background>
                        <SolidColorBrush Color="#15FF4444"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#30FF4444"/>
                    </Border.BorderBrush>
                    <Border.BorderThickness>
                        <Thickness>1</Thickness>
                    </Border.BorderThickness>
                    <TextBlock Text="删除" Foreground="#FF6666" FontSize="14" FontWeight="SemiBold"/>
                </Border>

                <!-- 取消 -->
                <Border Cursor="Hand" CornerRadius="8" Padding="16,10" Margin="0,0,10,0"
                        MouseLeftButtonDown="BtnCancel_Click"
                        MouseEnter="ActionBtn_MouseEnter" MouseLeave="ActionBtn_MouseLeave">
                    <Border.Background>
                        <SolidColorBrush Color="#15FFFFFF"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#20FFFFFF"/>
                    </Border.BorderBrush>
                    <Border.BorderThickness>
                        <Thickness>1</Thickness>
                    </Border.BorderThickness>
                    <TextBlock Text="取消" Foreground="#808090" FontSize="14" FontWeight="SemiBold"/>
                </Border>

                <!-- 保存 -->
                <Border x:Name="BtnSave" Cursor="Hand" CornerRadius="8" Padding="20,10"
                        MouseLeftButtonDown="BtnSave_Click"
                        MouseEnter="ActionBtn_MouseEnter" MouseLeave="ActionBtn_MouseLeave">
                    <Border.Background>
                        <SolidColorBrush Color="#25FF69B4"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#50FF69B4"/>
                    </Border.BorderBrush>
                    <Border.BorderThickness>
                        <Thickness>1</Thickness>
                    </Border.BorderThickness>
                    <TextBlock x:Name="TxtSave" Text="保存类别" Foreground="#FF69B4"
                               FontSize="14" FontWeight="Bold"/>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</Window>
```
