<UserControl x:Class="ConditioningControlPanel.FeatureSettingsPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="320" Background="Transparent">

    <Border Background="#1E1E3A" CornerRadius="10" BorderBrush="#FF69B4" BorderThickness="2"
            Padding="15">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- 头部区域 -->
                <RowDefinition Height="Auto"/>  <!-- 分钟设置区域 -->
                <RowDefinition Height="*"/>     <!-- 动态设置区域 -->
                <RowDefinition Height="Auto"/>  <!-- 按钮区域 -->
            </Grid.RowDefinitions>

            <!-- 头部 -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                <TextBlock x:Name="TxtIcon" Text="⚡" FontSize="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel>
                    <TextBlock x:Name="TxtFeatureName" Text="功能名称"
                               Foreground="#FF69B4" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtEventType" Text="开始事件"
                               Foreground="#888" FontSize="11"/>
                </StackPanel>
            </StackPanel>

            <!-- 分钟位置 -->
            <Grid Grid.Row="1" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="分钟" Foreground="#B0B0B0" FontSize="12" VerticalAlignment="Center"/>
                <Slider x:Name="SliderMinute" Grid.Column="1"
                        Minimum="0" Maximum="120" Value="0"
                        ValueChanged="SliderMinute_ValueChanged"/>
                <TextBlock x:Name="TxtMinuteValue" Grid.Column="2" Text="0"
                           Foreground="#E0E0E0" FontSize="12" FontWeight="SemiBold"
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>

            <!-- 动态设置区域 -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" MaxHeight="300">
                <StackPanel x:Name="SettingsPanel">
                    <!-- 设置项将动态生成 -->
                </StackPanel>
            </ScrollViewer>

            <!-- 按钮区域 -->
            <Grid Grid.Row="3" Margin="0,15,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnDelete" Content="删除" Click="BtnDelete_Click"
                        Background="#F44336" Foreground="White" Padding="15,8"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="5"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Grid.Column="2" x:Name="BtnDone" Content="完成" Click="BtnDone_Click"
                        Background="#FF69B4" Foreground="White" Padding="20,8"
                        FontWeight="SemiBold" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="5"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource PinkBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Grid>
    </Border>
</UserControl>
