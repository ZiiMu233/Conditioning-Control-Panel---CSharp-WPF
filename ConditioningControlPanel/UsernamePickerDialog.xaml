以下是汉化后的 `UsernamePickerDialog.xaml` 代码：

```xml
<Window x:Class="ConditioningControlPanel.UsernamePickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择您的显示名称" Height="350" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1A1A2E" WindowStyle="None" AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border BorderBrush="#FF69B4" BorderThickness="2" CornerRadius="10">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题 -->
            <TextBlock Grid.Row="0" Text="选择您的显示名称"
                       FontSize="24" FontWeight="Bold" Foreground="#FF69B4"
                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

            <!-- 新用户副标题 -->
            <TextBlock x:Name="TxtSubtitle" Grid.Row="1"
                       Text="此名称将显示在排行榜上并供其他用户查看。"
                       FontSize="12" Foreground="#B0B0B0" TextWrapping="Wrap"
                       HorizontalAlignment="Center" Margin="0,0,0,15"/>

            <!-- OG 欢迎消息（默认隐藏） -->
            <Border x:Name="OgWelcomePanel" Grid.Row="2" Visibility="Collapsed"
                    Background="#30FFD700" BorderBrush="#FFD700" BorderThickness="1"
                    CornerRadius="5" Padding="10" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="⭐ 欢迎回来，先驱！⭐"
                               FontSize="16" FontWeight="Bold" Foreground="#FFD700"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="您已被识别为第0赛季的OG！您的解锁和成就已恢复。"
                               FontSize="11" Foreground="White" TextWrapping="Wrap"
                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- 用户名输入 -->
            <StackPanel Grid.Row="3" Margin="0,0,0,10">
                <TextBlock Text="显示名称：" Foreground="White" FontSize="14" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtUsername" FontSize="18" Padding="10,8"
                         Background="#252542" Foreground="White" BorderBrush="#FF69B4"
                         MaxLength="30" TextChanged="TxtUsername_TextChanged"/>
                <TextBlock x:Name="TxtAvailability" FontSize="11" Margin="0,5,0,0"
                           Foreground="#B0B0B0" Text="输入唯一的显示名称（3-30个字符）"/>
            </StackPanel>

            <!-- 建议名称（来自旧账户或提供商） -->
            <StackPanel x:Name="SuggestionPanel" Grid.Row="4" Visibility="Collapsed" Margin="0,0,0,10">
                <TextBlock Text="您之前账户的建议名称："
                           Foreground="#B0B0B0" FontSize="11"/>
                <Button x:Name="BtnUseSuggestion" Content="" Padding="10,5"
                        Background="#352545" Foreground="#FF69B4" BorderThickness="0"
                        Cursor="Hand" Click="BtnUseSuggestion_Click" Margin="0,3,0,0"
                        HorizontalAlignment="Left"/>
            </StackPanel>

            <!-- 按钮 -->
            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button x:Name="BtnCancel" Content="取消" Padding="20,10"
                        Background="#352545" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="BtnCancel_Click" Margin="0,0,10,0"/>
                <Button x:Name="BtnConfirm" Content="确认" Padding="20,10"
                        Background="#FF69B4" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="BtnConfirm_Click" IsEnabled="False"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
```
