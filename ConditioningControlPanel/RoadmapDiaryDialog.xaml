<Window x:Class="ConditioningControlPanel.RoadmapDiaryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="转变日记"
        Width="500" Height="700"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True">

    <Border Background="#1A1A2E" BorderBrush="{StaticResource PinkBrush}" BorderThickness="2" CornerRadius="15">
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- 头部 -->
                <RowDefinition Height="Auto"/>  <!-- 照片 -->
                <RowDefinition Height="Auto"/>  <!-- 步骤信息 -->
                <RowDefinition Height="Auto"/>  <!-- 统计 -->
                <RowDefinition Height="*"/>     <!-- 笔记 -->
                <RowDefinition Height="Auto"/>  <!-- 按钮 -->
            </Grid.RowDefinitions>

            <!-- 头部及关闭按钮 -->
            <Grid Grid.Row="0" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock x:Name="TxtStepNumber" Text="步骤 1"
                               Foreground="#888888" FontSize="12"/>
                    <TextBlock x:Name="TxtStepTitle" Text="空白石板"
                               Foreground="{StaticResource PinkBrush}" FontSize="20" FontWeight="Bold"/>
                </StackPanel>
                <Button Content="X" HorizontalAlignment="Right" VerticalAlignment="Top"
                        Background="Transparent" Foreground="#888888"
                        BorderThickness="0" FontSize="16" FontWeight="Bold"
                        Cursor="Hand" Padding="5"
                        Click="BtnClose_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource PinkBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- 完整分辨率照片 -->
            <Border Grid.Row="1" CornerRadius="12" Background="#252542"
                    Margin="0,0,0,15" Height="280" ClipToBounds="True">
                <Grid>
                    <Image x:Name="ImgFullPhoto" Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock x:Name="TxtNoPhoto" Text="无可用照片"
                               Foreground="#666666" FontSize="14"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                </Grid>
            </Border>

            <!-- 目标/要求 -->
            <Border Grid.Row="2" Background="#252542" CornerRadius="10"
                    Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="目标" Foreground="#888888" FontSize="11" Margin="0,0,0,4"/>
                    <TextBlock x:Name="TxtObjective" Text="" Foreground="White"
                               FontSize="13" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- 完成统计 -->
            <Border Grid.Row="3" Background="#252542" CornerRadius="10"
                    Padding="15" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <TextBlock Text="完成日期" Foreground="#888888"
                                   FontSize="11" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TxtCompletedDate" Text="2024年1月15日"
                                   Foreground="White" FontSize="14" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        <TextBlock x:Name="TxtCompletedTime" Text="下午 3:45"
                                   Foreground="#888888" FontSize="11"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock Text="所用时间" Foreground="#888888"
                                   FontSize="11" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TxtTimeTaken" Text="45 分钟"
                                   Foreground="White" FontSize="14" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 用户笔记 -->
            <Border Grid.Row="4" Background="#252542" CornerRadius="10" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="个人笔记" Foreground="#888888"
                               FontSize="11" Margin="0,0,0,8"/>
                    <TextBox x:Name="TxtUserNote" Grid.Row="1"
                             Background="Transparent" Foreground="White"
                             BorderThickness="0" TextWrapping="Wrap"
                             AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                             FontSize="13" Padding="0"
                             CaretBrush="{StaticResource PinkBrush}"/>
                </Grid>
            </Border>

            <!-- 按钮 -->
            <StackPanel Grid.Row="5" Orientation="Horizontal"
                        HorizontalAlignment="Center" Margin="0,15,0,0">
                <Button Content="保存笔记" Background="{StaticResource PinkBrush}"
                        Foreground="White" Padding="20,10"
                        BorderThickness="0" Cursor="Hand" Margin="0,0,10,0"
                        FontWeight="Bold"
                        Click="BtnSaveNote_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FF1493"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="关闭" Background="#404060"
                        Foreground="White" Padding="20,10"
                        BorderThickness="0" Cursor="Hand"
                        Click="BtnClose_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#505080"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
