<Window x:Class="ConditioningControlPanel.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="输入"
        Height="180" Width="400"
        WindowStartupLocation="CenterOwner"
        Background="#1A1A2E"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="False"
        Topmost="True">

    <Window.Resources>
    </Window.Resources>

    <Border BorderBrush="{StaticResource PinkBrush}" BorderThickness="1" CornerRadius="0">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题 -->
            <TextBlock x:Name="TxtTitle" Grid.Row="0" Text="标题" 
                       Foreground="{StaticResource PinkBrush}" 
                       FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

            <!-- 提示信息 -->
            <TextBlock x:Name="TxtPrompt" Grid.Row="1" Text="请输入值：" 
                       Foreground="White" FontSize="12" Margin="0,0,0,8"/>

            <!-- 输入框 -->
            <TextBox x:Name="TxtInput" Grid.Row="2" 
                     Background="#252542" Foreground="White" 
                     BorderBrush="{StaticResource PinkBrush}"
                     Padding="10,8" FontSize="14"
                     KeyDown="TxtInput_KeyDown"/>

            <!-- 按钮区域 -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="取消" Width="80" Padding="10,8" Margin="0,0,10,0"
                        Background="#404060" Foreground="White" BorderThickness="0"
                        Click="BtnCancel_Click" Cursor="Hand"/>
                <Button Content="确定" Width="80" Padding="10,8"
                        Background="{StaticResource PinkBrush}" Foreground="White" 
                        BorderThickness="0" FontWeight="Bold"
                        Click="BtnOK_Click" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
