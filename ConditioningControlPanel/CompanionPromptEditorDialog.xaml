<Window x:Class="ConditioningControlPanel.CompanionPromptEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ConditioningControlPanel"
        Title="自定义 AI 伴侣"
        Width="700" Height="750"
        WindowStartupLocation="CenterOwner"
        Background="#1A1A2E"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <!-- 隐藏空描述的转换器 -->
        <local:NullOrEmptyToCollapsedConverter x:Key="NullToCollapsedConverter"/>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PinkBrush}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="SectionDescription" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#808080"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="PromptTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#252542"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#404060"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>

        <Style x:Key="ResetButton" TargetType="Button">
            <Setter Property="Background" Value="#404060"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#505080"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 头部 -->
        <Border Grid.Row="0" Background="#252542" Padding="20,15">
            <StackPanel>
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="自定义您的 AI 伴侣"
                                   Foreground="{StaticResource PinkBrush}"
                                   FontSize="20" FontWeight="Bold"/>
                        <Border Background="#FF6B6B" CornerRadius="3" Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="测试版" Foreground="White" FontSize="10" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                    <!-- 激活提示标记 -->
                    <Border x:Name="ActivePromptBadge" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Background="#1A1A2E" CornerRadius="12" Padding="12,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="当前激活：" Foreground="#707070" FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtActivePromptName" Text="默认" Foreground="#9370DB"
                                       FontSize="11" FontWeight="SemiBold" Margin="5,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
                <TextBlock Text="编辑控制伴侣思维和回应的提示词。关闭窗口时更改会自动保存。"
                           Foreground="#808080" FontSize="12" TextWrapping="Wrap" Margin="0,5,0,0"/>

                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <CheckBox x:Name="ChkUseCustom" Content="启用自定义提示词"
                              Foreground="White" VerticalContentAlignment="Center"
                              Checked="ChkUseCustom_Changed" Unchecked="ChkUseCustom_Changed"/>
                    <TextBlock Text="（取消勾选使用默认提示词）"
                               Foreground="#606060" FontSize="11"
                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 滚动内容区 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
            <StackPanel x:Name="ContentPanel">

                <!-- 第一部分：个性（普通模式） -->
                <Expander IsExpanded="True" Margin="0,0,0,15">
                    <Expander.Header>
                        <TextBlock Text="个性（普通模式）" Style="{StaticResource SectionHeader}"/>
                    </Expander.Header>
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Style="{StaticResource SectionDescription}">
                            定义你的伴侣是谁。他们的氛围、语调以及喜欢谈论的话题。此模式用于放荡模式关闭时。
                        </TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtPersonality" Style="{StaticResource PromptTextBox}"
                                     Height="120" TextChanged="OnTextChanged"/>
                            <Button Grid.Column="1" Content="重置" Style="{StaticResource ResetButton}"
                                    VerticalAlignment="Top" Margin="5,0,0,0"
                                    Click="ResetPersonality_Click"/>
                        </Grid>
                    </StackPanel>
                </Expander>

                <!-- 第二部分：敏感话题处理 -->
                <Expander IsExpanded="False" Margin="0,0,0,15">
                    <Expander.Header>
                        <TextBlock Text="敏感话题处理" Style="{StaticResource SectionHeader}"/>
                    </Expander.Header>
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Style="{StaticResource SectionDescription}">
                            在普通模式下，当你提到敏感话题时，你的伴侣应该如何反应？（放荡模式下，此设置被忽略，他们会直接回应。）
                        </TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtExplicitReaction" Style="{StaticResource PromptTextBox}"
                                     Height="100" TextChanged="OnTextChanged"/>
                            <Button Grid.Column="1" Content="重置" Style="{StaticResource ResetButton}"
                                    VerticalAlignment="Top" Margin="5,0,0,0"
                                    Click="ResetExplicitReaction_Click"/>
                        </Grid>
                    </StackPanel>
                </Expander>

                <!-- 第三部分：放荡模式个性 -->
                <Expander IsExpanded="False" Margin="0,0,0,15">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="放荡模式个性" Style="{StaticResource SectionHeader}"/>
                            <TextBlock Text="（Patreon）" Foreground="#9B59B6" FontSize="11"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Style="{StaticResource SectionDescription}">
                            定义放荡模式开启时伴侣的个性。这是更加露骨和触发式的。需要 Patreon 高级会员。
                        </TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtSlutMode" Style="{StaticResource PromptTextBox}"
                                     Height="140" TextChanged="OnTextChanged"/>
                            <Button Grid.Column="1" Content="重置" Style="{StaticResource ResetButton}"
                                    VerticalAlignment="Top" Margin="5,0,0,0"
                                    Click="ResetSlutMode_Click"/>
                        </Grid>
                    </StackPanel>
                </Expander>

                <!-- 第四部分：知识库 -->
                <Expander IsExpanded="False" Margin="0,0,0,15">
                    <Expander.Header>
                        <TextBlock Text="知识库" Style="{StaticResource SectionHeader}"/>
                    </Expander.Header>
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Style="{StaticResource SectionDescription}">
                            你的伴侣了解并可以推荐的音频、视频及资源。列出音频文件、视频系列、创作者等。
                        </TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtKnowledgeBase" Style="{StaticResource PromptTextBox}"
                                     Height="140" TextChanged="OnTextChanged"/>
                            <Button Grid.Column="1" Content="重置" Style="{StaticResource ResetButton}"
                                    VerticalAlignment="Top" Margin="5,0,0,0"
                                    Click="ResetKnowledgeBase_Click"/>
                        </Grid>
                    </StackPanel>
                </Expander>

                <!-- 第五部分：屏幕感知反应 -->
                <Expander IsExpanded="False" Margin="0,0,0,15">
                    <Expander.Header>
                        <TextBlock Text="屏幕感知反应" Style="{StaticResource SectionHeader}"/>
                    </Expander.Header>
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Style="{StaticResource SectionDescription}">
                            你的伴侣对你正在浏览的不同应用和网站会如何反应。伴侣会收到类似 [App: Chrome | Title: Reddit - r/BambiSleep] 的上下文。
                        </TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtContextReactions" Style="{StaticResource PromptTextBox}"
                                     Height="180" TextChanged="OnTextChanged"/>
                            <Button Grid.Column="1" Content="重置" Style="{StaticResource ResetButton}"
                                    VerticalAlignment="Top" Margin="5,0,0,0"
                                    Click="ResetContextReactions_Click"/>
                        </Grid>
                    </StackPanel>
                </Expander>

                <!-- 第六部分：输出规则 -->
                <Expander IsExpanded="False" Margin="0,0,0,15">
                    <Expander.Header>
                        <TextBlock Text="输出规则" Style="{StaticResource SectionHeader}"/>
                    </Expander.Header>
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Style="{StaticResource SectionDescription}">
                            控制回复长度、表情符号使用以及回复频率。保持回复简短，营造聊天氛围。
                        </TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtOutputRules" Style="{StaticResource PromptTextBox}"
                                     Height="100" TextChanged="OnTextChanged"/>
                            <Button Grid.Column="1" Content="重置" Style="{StaticResource ResetButton}"
                                    VerticalAlignment="Top" Margin="5,0,0,0"
                                    Click="ResetOutputRules_Click"/>
                        </Grid>
                    </StackPanel>
                </Expander>

                <!-- 第七部分：全局知识库链接 -->
                <Expander IsExpanded="False" Margin="0,0,0,15">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="全局知识库链接" Style="{StaticResource SectionHeader}"/>
                            <TextBlock Text="（所有个性）" Foreground="#50C878" FontSize="11"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Style="{StaticResource SectionDescription}">
                            添加你的伴侣知道并能推荐的催眠内容链接。这些链接适用于所有个性，无论哪个预设处于活动状态。
                        </TextBlock>

                        <!-- 链接列表 -->
                        <Border Background="#252542" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                            <ListBox x:Name="LstKnowledgeLinks" Height="120"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="White" FontSize="11"
                                     SelectionMode="Single">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,2">
                                            <TextBlock Text="{Binding Title}" Foreground="#FF69B4" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Url}" Foreground="#707070" FontSize="10"/>
                                            <TextBlock Text="{Binding Description}" Foreground="#A0A0A0" FontSize="10"
                                                       TextWrapping="Wrap" Visibility="{Binding Description, Converter={StaticResource NullToCollapsedConverter}}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <!-- 添加/删除按钮 -->
                        <StackPanel Orientation="Horizontal">
                            <Button Content="+ 添加链接" Style="{StaticResource ResetButton}"
                                    Padding="12,6" Click="AddKnowledgeLink_Click"/>
                            <Button Content="删除选中" Style="{StaticResource ResetButton}"
                                    Padding="12,6" Margin="8,0,0,0" Click="RemoveKnowledgeLink_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Expander>

            </StackPanel>
        </ScrollViewer>

        <!-- 底部栏 -->
        <Border Grid.Row="2" Background="#252542" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnResetAll" Content="全部重置为默认"
                        Style="{StaticResource ResetButton}"
                        HorizontalAlignment="Left"
                        Click="ResetAll_Click"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BtnCancel" Content="取消"
                            Style="{StaticResource SecondaryButton}"
                            Width="80" Margin="0,0,10,0"
                            Click="BtnCancel_Click"/>
                    <Button x:Name="BtnSave" Content="保存"
                            Style="{StaticResource ActionButton}"
                            Width="80"
                            Click="BtnSave_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
