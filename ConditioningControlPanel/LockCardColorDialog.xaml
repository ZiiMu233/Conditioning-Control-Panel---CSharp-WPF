<Window x:Class="ConditioningControlPanel.LockCardColorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="锁卡颜色" 
        Height="700" Width="600"
        WindowStartupLocation="CenterOwner"
        Background="#1A1A2E"
        ResizeMode="NoResize">

    <Window.Resources>
        
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 头部 -->
        <TextBlock Grid.Row="0" Text="🎨 锁卡颜色" 
                   Foreground="{StaticResource PinkBrush}" 
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- 颜色设置 -->
        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            
            <!-- 背景颜色 -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="背景" Foreground="{StaticResource TextLightBrush}" 
                           FontSize="14" VerticalAlignment="Center"/>
                <Button x:Name="BtnBgColor" Grid.Column="1" Style="{StaticResource ColorButtonLarge}"
                        Click="BtnBgColor_Click" ToolTip="点击更改背景颜色"/>
            </Grid>

            <!-- 短语文本颜色 -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="短语文本" Foreground="{StaticResource TextLightBrush}" 
                           FontSize="14" VerticalAlignment="Center"/>
                <Button x:Name="BtnTextColor" Grid.Column="1" Style="{StaticResource ColorButtonLarge}"
                        Click="BtnTextColor_Click" ToolTip="点击更改短语文本颜色"/>
            </Grid>

            <!-- 输入框背景颜色 -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="输入框背景" Foreground="{StaticResource TextLightBrush}" 
                           FontSize="14" VerticalAlignment="Center"/>
                <Button x:Name="BtnInputBgColor" Grid.Column="1" Style="{StaticResource ColorButtonLarge}"
                        Click="BtnInputBgColor_Click" ToolTip="点击更改输入框背景颜色"/>
            </Grid>

            <!-- 输入框文字颜色 -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="输入框文字" Foreground="{StaticResource TextLightBrush}" 
                           FontSize="14" VerticalAlignment="Center"/>
                <Button x:Name="BtnInputTextColor" Grid.Column="1" Style="{StaticResource ColorButtonLarge}"
                        Click="BtnInputTextColor_Click" ToolTip="点击更改输入框文字颜色"/>
            </Grid>

            <!-- 强调色 / 进度 -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="强调色 / 进度" Foreground="{StaticResource TextLightBrush}" 
                           FontSize="14" VerticalAlignment="Center"/>
                <Button x:Name="BtnAccentColor" Grid.Column="1" Style="{StaticResource ColorButtonLarge}"
                        Click="BtnAccentColor_Click" ToolTip="点击更改强调色（进度条、边框）"/>
            </Grid>
        </StackPanel>

        <!-- 预览区域 -->
        <Border Grid.Row="2" x:Name="PreviewBorder" Background="#1A1A2E" CornerRadius="8" 
                Padding="20" Margin="0,0,0,20">
            <StackPanel VerticalAlignment="Center">
                <!-- 标题 -->
                <TextBlock Text="📐 输入以解锁" Foreground="#FF69B4" FontSize="14" 
                           HorizontalAlignment="Center" Margin="0,0,0,15"/>
                
                <!-- 待输入短语 -->
                <TextBlock x:Name="PreviewPhrase" Text="乖女孩服从" 
                           FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,0,0,15"/>
                
                <!-- 输入框预览 -->
                <Border x:Name="PreviewInputBorder" Background="#252542" CornerRadius="6" 
                        Padding="15,10" Margin="0,0,0,15" BorderThickness="2">
                    <TextBlock x:Name="PreviewInputText" Text="乖女孩服|" 
                               FontSize="16" HorizontalAlignment="Center"/>
                </Border>
                
                <!-- 进度指示器 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock x:Name="PreviewProgress" Text="1 / 3" FontSize="12" Margin="0,0,10,0"/>
                    <Border Background="#404060" CornerRadius="3" Width="100" Height="6">
                        <Border x:Name="PreviewProgressBar" Background="#FF69B4" CornerRadius="3" 
                                Width="33" HorizontalAlignment="Left"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 按钮 -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" Content="取消" Style="{StaticResource SecondaryButton}" 
                    Margin="0,0,10,0" Click="BtnCancel_Click"/>
            <Button Grid.Column="2" Content="保存" Style="{StaticResource ActionButton}" 
                    Click="BtnSave_Click"/>
        </Grid>
    </Grid>
</Window>
