<Window x:Class="ConditioningControlPanel.AchievementPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="成就解锁！"
        Width="400" Height="200"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Background="#E0151530" CornerRadius="12" BorderBrush="{StaticResource PinkBrush}" BorderThickness="2"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="#FF69B4" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
        </Border.Effect>
        
        <Grid Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- 成就图片 -->
            <Border Grid.Column="0" Width="120" Height="120" Background="#1A1A2E" Margin="0,0,15,0">
                <Image x:Name="AchievementImage" Stretch="Uniform" Margin="5"/>
            </Border>
            
            <!-- 文本内容 -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <!-- 奖杯图标 + "成就解锁" -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock x:Name="TxtHeaderIcon" Text="🏆" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="TxtHeaderText" Text="成就已解锁！" Foreground="#FFD700"
                               FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
                
                <!-- 成就名称 -->
                <TextBlock x:Name="TxtName" Text="成就名称" 
                           Foreground="{StaticResource PinkBrush}" 
                           FontWeight="Bold" FontSize="18" 
                           TextWrapping="Wrap" Margin="0,0,0,8"/>
                
                <!-- 描述文字 -->
                <TextBlock x:Name="TxtFlavor" Text="描述文字在此..." 
                           Foreground="#AAAAAA" FontSize="12" 
                           TextWrapping="Wrap" FontStyle="Italic"/>
            </StackPanel>
            
            <!-- 关闭按钮 -->
            <Button Grid.Column="1" Content="✕" 
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Width="24" Height="24" Margin="0,-5,-5,0"
                    Background="Transparent" Foreground="#888888"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnClose_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Border>
</Window>
