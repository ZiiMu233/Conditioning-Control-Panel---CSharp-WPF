<Window x:Class="ConditioningControlPanel.ColorEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="潜意识颜色" 
        Height="480" Width="450"
        WindowStartupLocation="CenterOwner"
        Background="#1A1A2E"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- keep existing ToggleStyle... -->
      
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 头部 -->
        <TextBlock Grid.Row="0" Text="🎨 潜意识颜色" 
                   Foreground="{StaticResource PinkBrush}" 
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- 颜色设置 -->
        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            
            <!-- 背景颜色 -->
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="背景" Foreground="{StaticResource TextLightBrush}" 
                           FontSize="14" VerticalAlignment="Center"/>
                <Button x:Name="BtnBgColor" Grid.Column="1" Style="{StaticResource ColorButtonLarge}"
                        Click="BtnBgColor_Click" ToolTip="点击更改颜色"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="15,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="透明" Foreground="#808080" FontSize="11" 
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <CheckBox x:Name="ChkBgTransparent" Style="{StaticResource ToggleStyle}"/>
                </StackPanel>
            </Grid>

            <!-- 文本颜色 -->
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="文本" Foreground="{StaticResource TextLightBrush}" 
                           FontSize="14" VerticalAlignment="Center"/>
                <Button x:Name="BtnTextColor" Grid.Column="1" Style="{StaticResource ColorButtonLarge}"
                        Click="BtnTextColor_Click" ToolTip="点击更改颜色"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="15,0,0,0" VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <TextBlock Text="透明" Foreground="#808080" FontSize="11" 
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <CheckBox x:Name="ChkTextTransparent" Style="{StaticResource ToggleStyle}"/>
                </StackPanel>
            </Grid>

            <!-- 边框颜色 -->
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="边框/轮廓" Foreground="{StaticResource TextLightBrush}"
                           FontSize="14" VerticalAlignment="Center"/>
                <Button x:Name="BtnBorderColor" Grid.Column="1" Style="{StaticResource ColorButtonLarge}"
                        Click="BtnBorderColor_Click" ToolTip="点击更改颜色"/>
            </Grid>

            <!-- 抢占焦点开关 -->
            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="抢占键盘焦点" Foreground="{StaticResource TextLightBrush}"
                               FontSize="14"/>
                    <TextBlock Text="显示时通过抢占键盘焦点强制吸引注意"
                               Foreground="#808080" FontSize="10" Margin="0,2,0,0"/>
                </StackPanel>
                <CheckBox x:Name="ChkStealsFocus" Grid.Column="1" Style="{StaticResource ToggleStyle}"
                          VerticalAlignment="Center"/>
            </Grid>
        </StackPanel>

        <!-- 预览区域 -->
        <Border Grid.Row="2" x:Name="PreviewBorder" Background="Black" CornerRadius="8" 
                Height="80" Margin="0,0,0,20">
            <TextBlock x:Name="PreviewText" Text="好女孩"
                       FontSize="28" FontWeight="Bold" FontFamily="Arial"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <!-- 按钮 -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" Content="取消" Style="{StaticResource SecondaryButton}" 
                    Margin="0,0,10,0" Click="BtnCancel_Click"/>
            <Button Grid.Column="2" Content="保存" Style="{StaticResource ActionButton}" 
                    Click="BtnSave_Click"/>
        </Grid>
    </Grid>
</Window>
