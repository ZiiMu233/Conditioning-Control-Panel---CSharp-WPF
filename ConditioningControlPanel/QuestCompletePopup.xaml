<Window x:Class="ConditioningControlPanel.QuestCompletePopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="任务完成！"
        Width="350" Height="130"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Background="#E0151530" CornerRadius="12" BorderBrush="#00E676" BorderThickness="2"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="#00E676" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
        </Border.Effect>

        <Grid Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 对勾图标 -->
            <Border Grid.Column="0" Width="60" Height="60" Background="#2D4A2D" CornerRadius="30" Margin="0,0,15,0">
                <TextBlock Text="✓" Foreground="#00E676" FontSize="32" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <!-- 文本内容 -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="任务完成！" Foreground="#00E676"
                           FontWeight="Bold" FontSize="16" Margin="0,0,0,4"/>
                <TextBlock x:Name="TxtQuestName" Text="任务名称"
                           Foreground="White" FontSize="14" FontWeight="SemiBold"
                           TextWrapping="Wrap" Margin="0,0,0,4"/>
                <TextBlock x:Name="TxtXPAwarded" Text="+0 经验"
                           Foreground="#FFD700" FontSize="13" FontWeight="Bold"/>
            </StackPanel>

            <!-- 关闭按钮 -->
            <Button Grid.Column="1" Content="✕"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Width="24" Height="24" Margin="0,-5,-5,0"
                    Background="Transparent" Foreground="#888888"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnClose_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Border>
</Window>
