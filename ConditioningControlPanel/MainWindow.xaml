                                    <TextBox x:Name="TxtLockdownExit" Visibility="Collapsed"
                                             Background="#1A0A0A" Foreground="#DC143C" BorderBrush="#DC143C" BorderThickness="1"
                                             FontSize="12" Padding="6,4" Margin="0,6,0,0"
                                             KeyDown="TxtLockdownExit_KeyDown"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Quiz Training Card -->
                        <Border CornerRadius="12" Margin="6" Padding="15">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1A1A32" Offset="0"/>
                                    <GradientStop Color="#201A38" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#9B59B6" Offset="0"/>
                                    <GradientStop Color="#FF69B4" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.BorderThickness>
                                <Thickness>2</Thickness>
                            </Border.BorderThickness>
                            <StackPanel>
                                <Grid Margin="0,0,0,6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="测验训练" Foreground="White" FontWeight="Bold" FontSize="16"/>
                                        <TextBlock Text="[测试版]" Foreground="#9B59B6" FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </StackPanel>
                                    <Button x:Name="HelpBtnQuiz" Style="{StaticResource HelpButtonStyle}" HorizontalAlignment="Right" Tag="Quiz"/>
                                </Grid>
                                <TextBlock Text="AI 生成的个性测验。10 个问题，根据您的回答逐渐变得火辣。发现您真正的身份。"
                                           Foreground="#808090" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"/>

                                <CheckBox x:Name="ChkQuizFullscreen" Content="全屏" IsChecked="True"
                                          Foreground="#808090" FontSize="12" Margin="0,0,0,4"/>
                                <CheckBox x:Name="ChkQuizDrone" Content="后台播放无人机音效" IsChecked="False"
                                          Foreground="#808090" FontSize="12" Margin="0,0,0,10"/>

                                <Button x:Name="BtnStartQuiz" Content="开始测验" Cursor="Hand"
                                        Background="#9B59B6" Foreground="White" FontWeight="Bold" FontSize="12"
                                        BorderThickness="0" Padding="12,8" HorizontalAlignment="Left"
                                        Click="BtnStartQuiz_Click">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="8"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>

                                <TextBlock Text="过去的测验" Foreground="#808090" FontSize="11" Margin="0,10,0,4"
                                           x:Name="TxtPastQuizzesHeader" Visibility="Collapsed"/>
                                <Border MaxHeight="130" CornerRadius="6" x:Name="PastQuizzesPanel" Visibility="Collapsed"
                                        Background="#10FFFFFF" BorderBrush="#20FFFFFF" BorderThickness="1">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel x:Name="PastQuizzesList"/>
                                    </ScrollViewer>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Pop Quiz Card -->
                        <Border CornerRadius="12" Margin="6" Padding="15">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#20FF69B4" Offset="0"/>
                                    <GradientStop Color="#209B59B6" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#40FF69B4"/>
                            </Border.BorderBrush>
                            <Border.BorderThickness>
                                <Thickness>1</Thickness>
                            </Border.BorderThickness>
                            <StackPanel>
                                <TextBlock Text="突击测验" Foreground="White" FontWeight="Bold" FontSize="16" Margin="0,0,0,6"/>
                                <TextBlock Text="在会话期间弹出强化问题。所有答案都是正确的——纯粹积极的氛围。频率按会话小时计算。"
                                           Foreground="#808090" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"/>

                                <CheckBox x:Name="ChkPopQuizEnabled" Content="启用弹出问题"
                                          Foreground="#808090" FontSize="12" Margin="0,0,0,8"
                                          Checked="ChkPopQuizEnabled_Changed" Unchecked="ChkPopQuizEnabled_Changed"/>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="频率：" Foreground="#808090" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Slider x:Name="SliderPopQuizFrequency" Minimum="1" Maximum="100" Width="120"
                                            VerticalAlignment="Center"
                                            ValueChanged="SliderPopQuizFrequency_ValueChanged"/>
                                    <TextBlock x:Name="TxtPopQuizFrequency" Foreground="#B0B0C8" FontSize="12"
                                               VerticalAlignment="Center" Margin="8,0,0,0" Text="2/会话小时"/>
                                </StackPanel>

                                <Button x:Name="BtnTestPopQuiz" Content="测试" Cursor="Hand"
                                        Background="#9B59B6" Foreground="White" FontWeight="Bold" FontSize="12"
                                        BorderThickness="0" Padding="12,8" HorizontalAlignment="Left"
                                        Click="BtnTestPopQuiz_Click">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="8"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- Placeholder Card 4 -->
                        <Border Background="#12FFFFFF" CornerRadius="12" Margin="6" BorderBrush="#404060" BorderThickness="1">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="🔒" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock Text="即将推出" Foreground="#505070" FontSize="14" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </StackPanel>
            </ScrollViewer>

            <!-- Lab Smokescreen Overlay (Patreon T2 / Whitelist gate) -->
            <Border x:Name="LabSmokescreen" Background="#CC1A1A2E" IsHitTestVisible="True" Visibility="Visible">
                <Border Background="#20FFFFFF" CornerRadius="16" Padding="32,28" HorizontalAlignment="Center" VerticalAlignment="Center"
                        MaxWidth="360" BorderBrush="#60FF69B4" BorderThickness="1.5">
                    <Border.Effect>
                        <DropShadowEffect Color="#FF69B4" BlurRadius="30" ShadowDepth="0" Opacity="0.3"/>
                    </Border.Effect>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#x1F512;" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <Border Background="#30FF69B4" CornerRadius="8" Padding="12,4" HorizontalAlignment="Center" Margin="0,0,0,12">
                            <TextBlock Text="Beta 测试" Foreground="#FF69B4" FontWeight="Bold" FontSize="14"/>
                        </Border>
                        <TextBlock Text="这些实验性功能目前正在由 Patreon 支持者进行测试。"
                                   Foreground="#B0B0C8" FontSize="13" TextWrapping="Wrap" TextAlignment="Center" LineHeight="20" Margin="0,0,0,4"/>
                    </StackPanel>
                </Border>
            </Border>
            </Grid>
        </ContentControl>

        <!-- Leaderboard Tab -->
        <ContentControl x:Name="LeaderboardTab" Grid.Row="4" Margin="10,5,10,10" Visibility="Collapsed" Template="{StaticResource AnimatedTabBackground}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header with sort dropdown and refresh -->
                    <Border Grid.Row="0" Background="#20FF69B4" CornerRadius="12,12,0,0" Padding="20,15">
