                                                        <LineBreak/><Run Text="2."/><Run Text=" 点击 'Start Server'" Foreground="White"/>
                                                        <LineBreak/><Run Text="3."/><Run Text=" 点击 'Start Scanning' 搜索设备" Foreground="White"/>
                                                        <LineBreak/><Run Text="4."/><Run Text=" 使用：ws://localhost:12345" Foreground="#FF69B4"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </ToolTip>
                                        </TextBox.ToolTip>
