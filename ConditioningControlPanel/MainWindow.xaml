                                               FontSize="11" Foreground="#888" Margin="0,0,0,5" TextWrapping="Wrap"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <TextBlock Text="当前模式：" FontSize="11" Foreground="#AAA"/>
                                        <TextBlock x:Name="TxtHypnotubeModeLabel" Text="Bambi Sleep"
                                                   FontSize="11" Foreground="#FF69B4"/>
                                    </StackPanel>
                                    <TextBox x:Name="TxtHypnotubeLinks"
                                             MaxLength="2000"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="False"
                                             Height="60"
                                             VerticalScrollBarVisibility="Auto"
                                             Background="#1E1E3A"
                                             Foreground="White"
                                             BorderBrush="#505050"
                                             BorderThickness="1"
                                             Padding="8,6"
                                             Margin="0,0,0,10"
                                             Style="{StaticResource FocusGlowTextBox}"
                                             TextChanged="TxtHypnotubeLinks_TextChanged"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Divider -->
                        <Border Height="1" Margin="20,5,20,10" CornerRadius="1">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="Transparent" Offset="0"/>
                                    <GradientStop Color="#9370DB" Offset="0.5"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <!-- ROW 2: Settings + Quick Controls -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- SETTINGS BOX -->
                            <Border Grid.Column="0" CornerRadius="10" Padding="15" BorderThickness="1">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#1E1E3A" Offset="0"/>
                                        <GradientStop Color="#252548" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FF69B4" Offset="0"/>
                                        <GradientStop Color="#9B59B6" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                                <Border.Effect>
                                    <DropShadowEffect Color="#FF69B4" BlurRadius="12" ShadowDepth="0" Opacity="0.2"/>
                                </Border.Effect>
                                <StackPanel>
                                    <Grid Margin="0,0,0,15">
                                        <TextBlock Text="伴侣设置" Foreground="#FF69B4" FontSize="14" FontWeight="Bold"/>
                                        <Button x:Name="HelpBtnCompanionSettings" Style="{StaticResource HelpButtonStyle}" HorizontalAlignment="Right" Tag="CompanionSettings"/>
                                    </Grid>

                                    <!-- Show Companion -->
                                    <Grid Margin="0,0,0,12">
                                        <TextBlock Text="显示伴侣" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                        <CheckBox x:Name="ChkAvatarEnabledCompanion" Style="{StaticResource ToggleStyle}"
                                                  HorizontalAlignment="Right"
                                                  Checked="ChkAvatarEnabled_Changed" Unchecked="ChkAvatarEnabled_Changed"/>
                                    </Grid>

                                    <!-- Detach -->
                                    <Grid Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="窗口模式" Foreground="White" FontSize="13"/>
                                            <TextBlock x:Name="TxtDetachStatusCompanion" Text="锚定在主窗口"
                                                       Foreground="#707070" FontSize="11" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <Button x:Name="BtnDetachCompanionTab" Content="分离" HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Background="#1A1A32" Foreground="White" BorderBrush="#505050" BorderThickness="1"
                                                Padding="15,6" FontSize="12" Cursor="Hand" Click="BtnDetachCompanion_Click"/>
                                    </Grid>

                                    <!-- Idle Interval -->
                                    <Grid Margin="0,0,0,15">
                                        <StackPanel>
                                            <TextBlock Text="空闲咯咯间隔" Foreground="White" FontSize="13"/>
                                            <TextBlock Text="伴侣空闲时说话的频率" Foreground="#707070" FontSize="11" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <TextBlock x:Name="TxtIdleIntervalCompanion" Text="120秒" Foreground="#FF69B4"
                                                   FontSize="14" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                    <Slider x:Name="SliderIdleIntervalCompanion" Style="{StaticResource PinkSlider}"
                                            Minimum="5" Maximum="300" Value="120" Margin="0,0,0,15"
                                            ValueChanged="SliderIdleInterval_ValueChanged"/>

                                    <!-- Customize Button -->
                                    <Button x:Name="BtnCustomizeCompanion"
                                            Background="#1A1A32" Foreground="White" BorderBrush="#9370DB" BorderThickness="1"
                                            Padding="10,10" FontSize="13" Cursor="Hand" Click="BtnCustomizeCompanion_Click">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="自定义 AI · " Foreground="White"/>
                                            <TextBlock x:Name="TxtCustomizePromptName" Text="默认" Foreground="#9370DB" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Manage Phrases Button -->
                                    <Button x:Name="BtnManagePhrases"
                                            Background="#1A1A32" Foreground="White" BorderBrush="#FF69B4" BorderThickness="1"
                                            Padding="10,10" FontSize="13" Cursor="Hand" Margin="0,8,0,0"
                                            Click="BtnManagePhrases_Click">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="管理短语 · " Foreground="White"/>
                                            <TextBlock x:Name="TxtPhraseCount" Text="0 个激活" Foreground="#FF69B4" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Phrase Presets -->
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="CmbPhrasePresets" Grid.Column="0" FontSize="11"
                                                  Style="{StaticResource DarkComboBoxStyle}"
                                                  DisplayMemberPath="DisplayText"
                                                  SelectedValuePath="Id"
                                                  SelectionChanged="CmbPhrasePresets_SelectionChanged"/>
                                        <Button Content="保存" Grid.Column="1"
                                                Style="{StaticResource SmallPinkButton}"
                                                Padding="10,4" FontSize="11" Margin="6,0,0,0"
                                                ToolTip="将当前短语配置保存为预设"
                                                Click="BtnSavePhrasePreset_Click"/>
                                        <Button Content="删除" Grid.Column="2"
                                                Style="{StaticResource OutlineButton}"
                                                Padding="10,4" FontSize="11" Margin="4,0,0,0"
                                                ToolTip="删除选中的短语预设"
                                                Click="BtnDeletePhrasePreset_Click"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- QUICK CONTROLS BOX -->
                            <Border Grid.Column="2" CornerRadius="10" Padding="15" BorderThickness="1">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#1E1E3A" Offset="0"/>
                                        <GradientStop Color="#252548" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#9370DB" Offset="0"/>
                                        <GradientStop Color="#7B68EE" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                                <Border.Effect>
                                    <DropShadowEffect Color="#9370DB" BlurRadius="12" ShadowDepth="0" Opacity="0.2"/>
                                </Border.Effect>
                                <StackPanel>
                                    <Grid Margin="0,0,0,15">
                                        <TextBlock Text="快速控制" Foreground="#FF69B4" FontSize="14" FontWeight="Bold"/>
                                        <Button x:Name="HelpBtnQuickControls" Style="{StaticResource HelpButtonStyle}" HorizontalAlignment="Right" Tag="QuickControls"/>
                                    </Grid>

                                    <!-- Mute Avatar -->
                                    <Grid Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="静音头像" Foreground="White" FontSize="13"/>
                                            <TextBlock Text="隐藏对话气泡和声音" Foreground="#707070" FontSize="11" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <CheckBox x:Name="ChkMuteAvatarCompanion" Style="{StaticResource ToggleStyle}"
                                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                                  Checked="ChkMuteAvatar_Changed" Unchecked="ChkMuteAvatar_Changed"/>
                                    </Grid>

                                    <!-- Mute Whispers -->
                                    <Grid Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="静音低语" Foreground="White" FontSize="13"/>
                                            <TextBlock Text="静音潜意识音频" Foreground="#707070" FontSize="11" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <CheckBox x:Name="ChkMuteWhispersCompanion" Style="{StaticResource ToggleStyle}"
                                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                                  Checked="ChkMuteWhispers_Changed" Unchecked="ChkMuteWhispers_Changed"/>
                                    </Grid>

                                    <!-- Pause Browser -->
                                    <Grid Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="暂停浏览器" Foreground="White" FontSize="13"/>
                                            <TextBlock Text="暂停嵌入式浏览器音频" Foreground="#707070" FontSize="11" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <CheckBox x:Name="ChkPauseBrowserCompanion" Style="{StaticResource ToggleStyle}"
                                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                                  Checked="ChkPauseBrowser_Changed" Unchecked="ChkPauseBrowser_Changed"/>
                                    </Grid>

                                    <!-- Tips -->
                                    <Border CornerRadius="6" Padding="10" Margin="0,8,0,0" BorderBrush="#22808080" BorderThickness="1">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#16162B" Offset="0"/>
                                                <GradientStop Color="#1A1832" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Foreground="#606060" FontSize="11" TextWrapping="Wrap" TextAlignment="Center">
                                            <Run Text="点击头像查看进度 · 右键单击菜单 · 双击聊天"/>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- ROW 3: Triggers -->
                        <Border CornerRadius="10" Padding="15" BorderThickness="1">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1E1E3A" Offset="0"/>
                                    <GradientStop Color="#252548" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#9370DB" Offset="0"/>
                                    <GradientStop Color="#FF69B4" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.Effect>
                                <DropShadowEffect Color="#9370DB" BlurRadius="12" ShadowDepth="0" Opacity="0.15"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="触发模式" Foreground="#9370DB" FontSize="14" FontWeight="Bold"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text=" · 随机调节短语及音频" Foreground="#606060" FontSize="12"
                                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </StackPanel>

                                    <!-- Trigger Settings (shown when enabled) -->
                                    <StackPanel x:Name="TriggerSettingsPanelCompanion" Orientation="Horizontal" Visibility="Collapsed"
                                                Margin="0,12,0,0">
                                        <TextBlock Text="间隔：" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                                        <Slider x:Name="SliderTriggerIntervalCompanion" Style="{StaticResource PinkSlider}"
                                                Width="150" Minimum="10" Maximum="600" Value="60"
                                                VerticalAlignment="Center" Margin="10,0,0,0"
                                                ValueChanged="SliderTriggerInterval_ValueChanged"/>
                                        <TextBlock x:Name="TxtTriggerIntervalCompanion" Text="60秒" Foreground="#9370DB"
                                                   FontSize="13" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        <Button x:Name="BtnEditTriggersCompanion" Content="编辑短语"
                                                Background="#1A1A32" Foreground="White" BorderBrush="#505050" BorderThickness="1"
                                                Padding="12,4" FontSize="11" Margin="20,0,0,0" Cursor="Hand"
                                                Click="BtnEditTriggers_Click"/>
                                    </StackPanel>
                                </StackPanel>

                                <CheckBox x:Name="ChkTriggerModeCompanion" Grid.Column="1" Style="{StaticResource ToggleStyle}"
                                          VerticalAlignment="Top" Margin="0,2,0,0"
                                          Checked="ChkTriggerMode_Changed" Unchecked="ChkTriggerMode_Changed"/>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </ContentControl>

        <!-- Patreon Exclusives Tab -->
        <ContentControl x:Name="PatreonTab" Grid.Row="4" Margin="10,5,10,10" Visibility="Collapsed" Template="{StaticResource AnimatedTabBackground}">
            <Border Style="{StaticResource SectionPanel}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15">
                        <Grid Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="Patreon 专属" Foreground="White" FontSize="22" FontWeight="Bold">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#FF69B4" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                                <TextBlock Text="支持者专属功能" Foreground="#666680" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button x:Name="HelpBtnPatreon" Style="{StaticResource HelpButtonStyle}" HorizontalAlignment="Right" Tag="PatreonExclusives"/>
                        </Grid>

                        <!-- Patreon Login Status -->
                        <Border CornerRadius="10" Padding="15" Margin="0,0,0,15"
                                BorderBrush="#FF424D" BorderThickness="1">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1A1A2E" Offset="0"/>
                                    <GradientStop Color="#1E1E3A" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#FF424D" BlurRadius="15" ShadowDepth="0" Opacity="0.3"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock x:Name="TxtPatreonStatus" Text="未连接" Foreground="White" FontSize="14" FontWeight="Bold"/>
                                    <TextBlock x:Name="TxtPatreonTier" Text="登录以解锁专属功能" Foreground="#808080" FontSize="12"/>
                                </StackPanel>

                                <Button x:Name="BtnPatreonLogin" Grid.Column="1"
                                        Content="登录"
                                        Background="#FF424D" Foreground="White"
                                        BorderThickness="0" Padding="15,8"
                                        FontWeight="Bold" FontSize="12"
                                        Cursor="Hand"
                                        Click="BtnPatreonLogin_Click"/>
                            </Grid>
                        </Border>

                        <!-- Discord Login Status -->
                        <Border CornerRadius="10" Padding="15" Margin="0,0,0,15"
                                BorderBrush="#5865F2" BorderThickness="1">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1A1A2E" Offset="0"/>
                                    <GradientStop Color="#1E1E3A" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#5865F2" BlurRadius="15" ShadowDepth="0" Opacity="0.3"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock x:Name="TxtDiscordStatus" Text="未连接" Foreground="White" FontSize="14" FontWeight="Bold"/>
                                    <TextBlock x:Name="TxtDiscordInfo" Text="链接 Discord 以使用社区功能" Foreground="#808080" FontSize="12"/>
                                </StackPanel>

                                <Button x:Name="BtnDiscordLogin" Grid.Column="1"
                                        Content="登录"
                                        Background="#5865F2" Foreground="White"
                                        BorderThickness="0" Padding="15,8"
                                        FontWeight="Bold" FontSize="12"
                                        Cursor="Hand"
                                        Click="BtnDiscordLogin_Click"/>
                            </Grid>
                        </Border>

                        <!-- Account Linking Section (visible when logged in but other provider not linked) -->
                        <Border x:Name="AccountLinkingSection" Background="#1A1A2E" CornerRadius="8" Padding="15" Margin="0,0,0,15"
                                BorderBrush="#FFD700" BorderThickness="1" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="链接账户" Foreground="#FFD700" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                                <TextBlock Text="链接两个提供商，以便您可以通过任一登录方式访问您的账户。"
                                           Foreground="#B0B0B0" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"/>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button x:Name="BtnLinkPatreon"
                                            Content="⭐ 链接 Patreon"
                                            Background="#FF424D" Foreground="White"
                                            BorderThickness="0" Padding="15,8" Margin="0,0,10,0"
                                            FontWeight="Bold" FontSize="12"
                                            Cursor="Hand" Visibility="Collapsed"
                                            Click="BtnLinkPatreon_Click"/>
                                    <Button x:Name="BtnLinkDiscord"
                                            Content="🎮 链接 Discord"
                                            Background="#5865F2" Foreground="White"
                                            BorderThickness="0" Padding="15,8"
                                            FontWeight="Bold" FontSize="12"
                                            Cursor="Hand" Visibility="Collapsed"
                                            Click="BtnLinkDiscord_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Cloud Settings Backup Section (visible when user has cloud identity) -->
                        <Border x:Name="CloudSettingsBackupSection" Background="#1A1A2E" CornerRadius="8" Padding="15" Margin="0,0,0,15"
                                BorderBrush="#9B59B6" BorderThickness="1" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="云端设置备份" Foreground="#9B59B6" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                                <TextBlock x:Name="TxtCloudBackupStatus"
                                           Text="检查备份状态..."
                                           Foreground="#B0B0B0" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"/>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button x:Name="BtnBackupSettingsNow"
                                            Content="☁ 立即备份"
                                            Background="#9B59B6" Foreground="White"
                                            BorderThickness="0" Padding="15,8" Margin="0,0,10,0"
                                            FontWeight="Bold" FontSize="12"
                                            Cursor="Hand"
                                            Click="BtnBackupSettingsNow_Click"/>
                                    <Button x:Name="BtnRestoreSettings"
                                            Content="从云端还原"
                                            Background="Transparent" Foreground="#9B59B6"
                                            BorderBrush="#9B59B6" BorderThickness="1" Padding="15,8"
                                            FontWeight="Bold" FontSize="12"
                                            Cursor="Hand"
                                            Click="BtnRestoreSettings_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Data & Privacy Section (visible when user has cloud identity) -->
                        <Border x:Name="DataPrivacySection" Background="#1A1A2E" CornerRadius="8" Padding="15" Margin="0,0,0,15"
                                BorderBrush="#555" BorderThickness="1" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="数据与隐私" Foreground="#B0B0B0" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                                <TextBlock Text="导出您的云端数据或查看我们的隐私政策。"
                                           Foreground="#888" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"/>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button x:Name="BtnExportData"
                                            Content="导出我的数据"
                                            Background="#555" Foreground="White"
                                            BorderThickness="0" Padding="15,8" Margin="0,0,10,0"
                                            FontWeight="Bold" FontSize="12"
                                            Cursor="Hand"
                                            Click="BtnExportData_Click"/>
                                    <Button x:Name="BtnPrivacyPolicy"
                                            Content="隐私政策"
                                            Background="Transparent" Foreground="#888"
                                            BorderBrush="#555" BorderThickness="1" Padding="15,8"
                                            FontWeight="Bold" FontSize="12"
                                            Cursor="Hand"
                                            Click="BtnPrivacyPolicy_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- 2-Column Grid of Feature Expanders (wrapped with Patreon lock overlay) -->
                        <Grid Margin="0,10,0,0">
                        <!-- Patreon-Only Overlay for entire features grid -->
                        <Border x:Name="PatreonFeaturesOverlay" Background="#CC1A1A2E" CornerRadius="12" Panel.ZIndex="100">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="🔒" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                <TextBlock Text="Patreon 专属功能" Foreground="#FF69B4" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#FF69B4" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                                <TextBlock Text="支持 Patreon 以解锁自主模式、远程控制、关键词触发、触觉反馈等功能"
                                           Foreground="#AAAAAA" FontSize="13" HorizontalAlignment="Center" Margin="0,10,0,0" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="400"/>
                                <Button Content="访问 Patreon" Background="#FF424D" Foreground="White"
                                        BorderThickness="0" Padding="20,10" Margin="0,18,0,0"
                                        FontWeight="Bold" FontSize="13" Cursor="Hand"
                                        Click="BtnVisitPatreon_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#E8363F"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Border>
                        <!-- Actual features grid -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Row 0, Col 0: Bambi Takeover -->
                            <Expander Grid.Row="0" Grid.Column="0" Style="{StaticResource ExclusivesSectionExpander}">
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="TxtTakeoverHeader" Text="🤖 Bambi 接管" Foreground="White" FontSize="14" FontWeight="Bold"/>
                                    </StackPanel>
                                </Expander.Header>
                                <StackPanel>
                                <Grid>
                                    <!-- Locked State -->
                                    <StackPanel x:Name="AutonomyLocked" Visibility="Visible">
                                        <Grid>
                                            <TextBlock x:Name="TxtTakeoverLocked" Text="🤖 Bambi 接管" Foreground="#666666" FontWeight="Bold" FontSize="13"/>
                                            <TextBlock x:Name="TxtAutonomyLockStatus" Text="🔒 Patreon 专属" Foreground="#9B59B6" HorizontalAlignment="Right" FontSize="11"/>
                                        </Grid>
                                        <TextBlock x:Name="TxtAutonomyLockMessage" Text="支持 Patreon 以解锁" Foreground="{StaticResource PinkBrush}" FontSize="11" Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <!-- Unlocked State -->
                                    <StackPanel x:Name="AutonomyUnlocked" Visibility="Collapsed">
                                        <!-- Header -->
                                        <Grid>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="TxtTakeoverUnlocked" Text="🤖 Bambi 接管" Foreground="{StaticResource PinkBrush}" FontWeight="Bold" FontSize="13"/>
                                                <Border Background="#2A1A3A" CornerRadius="4" Padding="6,2" Margin="8,0,0,0" BorderBrush="#FF69B4" BorderThickness="1">
                                                    <TextBlock Text="无需引擎" Foreground="#FF69B4" FontSize="9"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>

                                        <StackPanel x:Name="AutonomySettings" Margin="0,8,0,0">
                                            <!-- Sliders: 2x2 grid -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="6"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <StackPanel Grid.Row="0" Grid.Column="0">
                                                    <Grid><TextBlock Text="间隔" Foreground="#AAA" FontSize="10"/><TextBlock x:Name="TxtAutonomyInterval" Text="60秒" Foreground="#FF69B4" FontSize="10" HorizontalAlignment="Right"/></Grid>
                                                    <Slider x:Name="SliderAutonomyInterval" Minimum="30" Maximum="300" Value="60" Height="18" ValueChanged="SliderAutonomyInterval_Changed"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="0" Grid.Column="2">
                                                    <Grid><TextBlock Text="冷却" Foreground="#AAA" FontSize="10"/><TextBlock x:Name="TxtAutonomyCooldown" Text="30秒" Foreground="#FF69B4" FontSize="10" HorizontalAlignment="Right"/></Grid>
                                                    <Slider x:Name="SliderAutonomyCooldown" Minimum="10" Maximum="300" Value="30" Height="18" ValueChanged="SliderAutonomyCooldown_Changed"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="2" Grid.Column="0">
                                                    <Grid><TextBlock Text="强度" Foreground="#AAA" FontSize="10"/><TextBlock x:Name="TxtAutonomyIntensity" Text="5" Foreground="#FF69B4" FontSize="10" HorizontalAlignment="Right"/></Grid>
                                                    <Slider x:Name="SliderAutonomyIntensity" Minimum="1" Maximum="10" Value="5" Height="18" ValueChanged="SliderAutonomyIntensity_Changed"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="2" Grid.Column="2">
                                                    <Grid><TextBlock Text="通知" Foreground="#AAA" FontSize="10"/><TextBlock x:Name="TxtAutonomyAnnounce" Text="50%" Foreground="#FF69B4" FontSize="10" HorizontalAlignment="Right"/></Grid>
                                                    <Slider x:Name="SliderAutonomyAnnounce" Minimum="0" Maximum="100" Value="50" Height="18" ValueChanged="SliderAutonomyAnnounce_Changed"/>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Checkboxes: 3 columns -->
                                            <Grid Margin="0,10,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Triggers -->
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="触发" Foreground="#FF69B4" FontWeight="Bold" FontSize="10" Margin="0,0,0,2"/>
                                                    <Grid Margin="0,1"><TextBlock Text="空闲" FontSize="10" Foreground="#CCC"/><CheckBox x:Name="ChkAutonomyIdle" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" Checked="ChkAutonomyIdle_Changed" Unchecked="ChkAutonomyIdle_Changed"/></Grid>
                                                    <Grid Margin="0,1"><TextBlock Text="随机" FontSize="10" Foreground="#CCC"/><CheckBox x:Name="ChkAutonomyRandom" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" Checked="ChkAutonomyRandom_Changed" Unchecked="ChkAutonomyRandom_Changed"/></Grid>
                                                    <Grid Margin="0,1"><TextBlock Text="时间感知" FontSize="10" Foreground="#CCC"/><CheckBox x:Name="ChkAutonomyTimeAware" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" Checked="ChkAutonomyTimeAware_Changed" Unchecked="ChkAutonomyTimeAware_Changed"/></Grid>
                                                </StackPanel>
                                                <!-- Basic -->
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="基本" Foreground="#FF69B4" FontWeight="Bold" FontSize="10" Margin="0,0,0,2"/>
                                                    <Grid Margin="0,1"><TextBlock Text="闪图" FontSize="10" Foreground="#CCC"/><CheckBox x:Name="ChkAutonomyFlash" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" Checked="ChkAutonomyBehavior_Changed" Unchecked="ChkAutonomyBehavior_Changed"/></Grid>
                                                    <Grid Margin="0,1"><TextBlock Text="视频" FontSize="10" Foreground="#CCC"/><CheckBox x:Name="ChkAutonomyVideo" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" Checked="ChkAutonomyBehavior_Changed" Unchecked="ChkAutonomyBehavior_Changed"/></Grid>
                                                    <Grid Margin="0,1"><TextBlock Text="网页视频" FontSize="10" Foreground="#CCC" ToolTip="自动全屏播放 HypnoTube 视频"/><CheckBox x:Name="ChkAutonomyWebVideo" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" Checked="ChkAutonomyBehavior_Changed" Unchecked="ChkAutonomyBehavior_Changed"/></Grid>
                                                    <Grid Margin="0,1"><TextBlock Text="潜意识" FontSize="10" Foreground="#CCC"/><CheckBox x:Name="ChkAutonomySubliminal" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" Checked="ChkAutonomyBehavior_Changed" Unchecked="ChkAutonomyBehavior_Changed"/></Grid>
                                                    <Grid Margin="0,1"><TextBlock Text="评论" FontSize="10" Foreground="#CCC"/><CheckBox x:Name="ChkAutonomyComment" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" Checked="ChkAutonomyBehavior_Changed" Unchecked="ChkAutonomyBehavior_Changed"/></Grid>
                                                </StackPanel>
                                                <!-- Advanced -->
                                                <StackPanel Grid.Column="4">
                                                    <TextBlock Text="高级" Foreground="#FF69B4" FontWeight="Bold" FontSize="10" Margin="0,0,0,2"/>
                                                    <Grid Margin="0,1"><TextBlock Text="泡泡" FontSize="10" Foreground="#CCC"/><CheckBox x:Name="ChkAutonomyBubbles" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" Checked="ChkAutonomyBehavior_Changed" Unchecked="ChkAutonomyBehavior_Changed"/></Grid>
                                                    <Grid Margin="0,1"><TextBlock Text="粉色滤镜" FontSize="10" Foreground="#CCC"/><CheckBox x:Name="ChkAutonomyPinkFilter" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" Checked="ChkAutonomyBehavior_Changed" Unchecked="ChkAutonomyBehavior_Changed"/></Grid>
                                                    <Grid Margin="0,1"><TextBlock Text="锁卡" FontSize="10" Foreground="#CCC"/><CheckBox x:Name="ChkAutonomyLockCard" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" Checked="ChkAutonomyBehavior_Changed" Unchecked="ChkAutonomyBehavior_Changed"/></Grid>
                                                    <Grid Margin="0,1"><TextBlock Text="弹跳文字" FontSize="10" Foreground="#CCC"/><CheckBox x:Name="ChkAutonomyBouncingText" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" Checked="ChkAutonomyBehavior_Changed" Unchecked="ChkAutonomyBehavior_Changed"/></Grid>
                                                    <Grid Margin="0,1"><TextBlock Text="大脑擦除" FontSize="10" Foreground="#CCC"/><CheckBox x:Name="ChkAutonomyMindWipe" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" Checked="ChkAutonomyBehavior_Changed" Unchecked="ChkAutonomyBehavior_Changed"/></Grid>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Buttons -->
                                            <Grid Margin="0,10,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Button x:Name="BtnAutonomyStartStop" Grid.Column="0" Content="▶ 开始" Background="#2A1A3A" Foreground="#90EE90"
                                                        FontWeight="Bold" FontSize="12" Padding="12,6"
                                                        Click="BtnAutonomyStartStop_Click" ToolTip="开始/停止 Bambi 接管"/>
                                                <Button Grid.Column="2" Content="测试" Background="#FF69B4" Foreground="White" FontWeight="Bold" FontSize="11"
                                                        Padding="12,6" Click="BtnTestAutonomy_Click" ToolTip="测试操作"/>
                                            </Grid>

                                            <!-- Hidden elements -->
                                            <CheckBox x:Name="ChkAutonomySpiral" Visibility="Collapsed" Checked="ChkAutonomyBehavior_Changed" Unchecked="ChkAutonomyBehavior_Changed"/>
                                            <CheckBox x:Name="ChkAutonomyBubbleCount" Visibility="Collapsed" Checked="ChkAutonomyBehavior_Changed" Unchecked="ChkAutonomyBehavior_Changed"/>
                                            <Button x:Name="BtnForceStartAutonomy" Visibility="Collapsed" Click="BtnForceStartAutonomy_Click"/>
                                            <CheckBox x:Name="ChkAutonomyEnabled" Visibility="Collapsed" Checked="ChkAutonomyEnabled_Changed" Unchecked="ChkAutonomyEnabled_Changed"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>

                                <!-- Feature Image -->
                                <Border Background="#1E1E3A" CornerRadius="8" Padding="8" Margin="0,10,0,0">
                                    <StackPanel>
                                        <TextBlock Text="让她接管控制" Foreground="{StaticResource PinkBrush}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        <TextBlock Text="她将根据您的设置自主触发效果"
                                                   Foreground="#808080" FontSize="10" TextWrapping="Wrap" TextAlignment="Center" Margin="0,4,0,8"/>
                                        <Image x:Name="ImgTakeover" Source="pack://application:,,,/Resources/features/bambi takeover.png"
                                               Stretch="Uniform" MaxHeight="160"/>
                                    </StackPanel>
                                </Border>
                                </StackPanel>
                            </Expander>

                            <!-- Row 0, Col 2: Remote Control -->
                            <Expander Grid.Row="0" Grid.Column="2" Style="{StaticResource ExclusivesSectionExpander}">
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🎮 远程控制" Foreground="White" FontSize="14" FontWeight="Bold"/>
                                    </StackPanel>
                                </Expander.Header>
                                <StackPanel>
                                    <!-- Header row with toggle -->
                                    <Grid Margin="0,0,0,10">
                                        <TextBlock Foreground="#808080" FontSize="11" TextWrapping="Wrap">
                                            <Run Text="将控制权交给您信任的人。他们将获得一个移动友好的控制面板，可以在您的屏幕上实时触发闪图、视频、覆盖层、触觉反馈等。选择权限等级以设定界限。您始终拥有紧急键。"/>
                                        </TextBlock>
                                    </Grid>
                                    <Grid Margin="0,0,0,10">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <Button x:Name="HelpBtnRemoteControl" Style="{StaticResource HelpButtonStyle}"
                                                    VerticalAlignment="Center" Margin="0,0,8,0" Tag="RemoteControl" Panel.ZIndex="1"/>
                                            <CheckBox x:Name="ChkRemoteControlEnabled" Style="{StaticResource ToggleStyle}"
                                                      Checked="ChkRemoteControlEnabled_Changed" Unchecked="ChkRemoteControlEnabled_Changed"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Settings (visible when active) -->
                                    <StackPanel x:Name="RemoteControlPanel" Visibility="Collapsed">
                                        <!-- Tier selection -->
                                        <Grid Margin="0,0,0,10">
                                            <TextBlock Text="权限等级：" Foreground="#C0C0C0" FontSize="12" VerticalAlignment="Center"/>
                                            <ComboBox x:Name="CmbRemoteTier" HorizontalAlignment="Right" Width="130"
                                                      Style="{StaticResource DarkComboBoxStyle}" FontSize="12"
                                                      SelectionChanged="CmbRemoteTier_SelectionChanged">
                                                <ComboBoxItem Content="轻量" IsSelected="True"/>
                                                <ComboBoxItem Content="标准"/>
                                                <ComboBoxItem Content="完整"/>
                                            </ComboBox>
                                        </Grid>

                                        <!-- Controller Link -->
                                        <Border x:Name="RemoteLinkPanel" Background="#0D0D1A" CornerRadius="8" Padding="10,8" Margin="0,0,0,6"
                                                BorderBrush="#353550" BorderThickness="1" Visibility="Collapsed">
                                            <Grid>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="🔗" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="codebambi.github.io/.../remote" Foreground="#9B59B6" FontSize="11"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <Button x:Name="BtnCopyRemoteLink" Content="复制链接" Background="#353550" Foreground="White"
                                                        FontSize="10" Padding="8,3" BorderThickness="0" Cursor="Hand"
                                                        HorizontalAlignment="Right" VerticalAlignment="Center"
                                                        Click="BtnCopyRemoteLink_Click"/>
                                            </Grid>
                                        </Border>

                                        <!-- Session Code Display -->
                                        <Border x:Name="RemoteCodePanel" Background="#0D0D1A" CornerRadius="8" Padding="15,12" Margin="0,0,0,10"
                                                BorderBrush="#353550" BorderThickness="1" Visibility="Collapsed">
                                            <Grid>
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="会 话 代 码" Foreground="#808080" FontSize="10" FontWeight="Bold"
                                                               HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                                    <TextBlock x:Name="TxtRemoteCode" Text="- - - - - - - -" Foreground="#FF69B4"
                                                               FontSize="28" FontWeight="Bold" FontFamily="Consolas"
                                                               HorizontalAlignment="Center"/>
                                                    <TextBlock x:Name="TxtRemotePin" Text="" Foreground="#9B59B6"
                                                               FontSize="16" FontWeight="Bold" FontFamily="Consolas"
                                                               HorizontalAlignment="Center" Margin="0,4,0,0"
                                                               Visibility="Collapsed"/>
                                                </StackPanel>
                                                <Button x:Name="BtnCopyRemoteCode" Content="复制" Background="#353550" Foreground="White"
                                                        FontSize="11" Padding="10,4" BorderThickness="0" Cursor="Hand"
                                                        HorizontalAlignment="Right" VerticalAlignment="Center"
                                                        Click="BtnCopyRemoteCode_Click"/>
                                            </Grid>
                                        </Border>

                                        <!-- Connection Status -->
                                        <StackPanel x:Name="RemoteStatusPanel" Orientation="Horizontal" Margin="0,0,0,10" Visibility="Collapsed">
                                            <Ellipse x:Name="RemoteStatusDot" Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TxtRemoteStatus" Text="等待控制器连接..." Foreground="#A0A0A0" FontSize="12"/>
                                        </StackPanel>

                                        <!-- Stop button -->
                                        <Button x:Name="BtnStopRemote" Content="停止会话" Background="#FF4444" Foreground="White"
                                                FontWeight="Bold" FontSize="12" Padding="15,8" BorderThickness="0" Cursor="Hand"
                                                Margin="0,0,0,10" Visibility="Collapsed"
                                                Click="BtnStopRemote_Click"/>

                                        <!-- Info notice -->
                                        <TextBlock TextWrapping="Wrap" Foreground="#666680" FontSize="10" Margin="0,4,0,0">
                                            <Run Text="所有触发都使用您本地的媒体文件。控制器只能触发操作 — 他们无法看到您的屏幕或文件。"/>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>

                            <!-- Row 1, Col 0: Keyword Triggers -->
                            <Expander Grid.Row="1" Grid.Column="0" Style="{StaticResource ExclusivesSectionExpander}">
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⌨️ 关键词触发" Foreground="White" FontSize="14" FontWeight="Bold"/>
                                    </StackPanel>
                                </Expander.Header>
                                <StackPanel>
                                    <!-- Header row -->
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="关键词触发" Foreground="#FF69B4" FontSize="13" FontWeight="Bold"/>
                                            <TextBlock x:Name="TxtKeywordTriggersLocked" Text="  对 Patreon 支持者进行 Beta 测试"
                                                       Foreground="#DAA520" FontSize="10" FontStyle="Italic" VerticalAlignment="Center" Margin="8,0,0,0"
                                                       Visibility="Collapsed"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <Button x:Name="HelpBtnKeywordTriggers" Style="{StaticResource HelpButtonStyle}"
                                                    VerticalAlignment="Center" Margin="0,0,8,0" Tag="KeywordTriggers" Panel.ZIndex="1"/>
                                            <Button x:Name="BtnKeywordTriggersStartStop" Content="开始"
                                                    Background="#FF69B4" Foreground="White" FontWeight="Bold" FontSize="11"
                                                    Padding="14,4" BorderThickness="0" Cursor="Hand"
                                                    Click="BtnKeywordTriggersStartStop_Click"/>
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Foreground="#808080" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap">
                                            <Run Text="您日常的打字将成为调节的一部分。添加触发词，当您在电脑上键入它们时，就会触发音频、视觉或触觉反馈。启用屏幕 OCR 还可以对屏幕上看到的单词做出反应。"/>
                                        </TextBlock>

                                    <!-- Settings panel -->
                                    <StackPanel x:Name="KeywordTriggersSettingsPanel" Margin="0,10,0,0">

                                        <!-- Global settings row -->
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Buffer timeout -->
                                            <StackPanel Grid.Column="0" Margin="0,0,6,0"
                                                        ToolTip="击键后等待多长时间再检查关键词匹配">
                                                <TextBlock Text="缓冲区超时" Foreground="#A0A0A0" FontSize="10"/>
                                                <Grid>
                                                    <Slider x:Name="SliderKeywordBufferTimeout" Minimum="1000" Maximum="10000"
                                                            TickFrequency="500" IsSnapToTickEnabled="True"
                                                            ValueChanged="SliderKeywordBufferTimeout_ValueChanged"/>
                                                    <TextBlock x:Name="TxtKeywordBufferTimeout" Text="3.0秒"
                                                               Foreground="#FF69B4" FontSize="10" HorizontalAlignment="Right" IsHitTestVisible="False"/>
                                                </Grid>
                                            </StackPanel>

                                            <!-- Global cooldown -->
                                            <StackPanel Grid.Column="1" Margin="6,0,6,0"
                                                        ToolTip="任意两次触发激活之间的最小时间间隔">
                                                <TextBlock Text="全局冷却" Foreground="#A0A0A0" FontSize="10"/>
                                                <Grid>
                                                    <Slider x:Name="SliderKeywordGlobalCooldown" Minimum="1" Maximum="120"
                                                            TickFrequency="1" IsSnapToTickEnabled="True"
                                                            ValueChanged="SliderKeywordGlobalCooldown_ValueChanged"/>
                                                    <TextBlock x:Name="TxtKeywordGlobalCooldown" Text="5秒"
                                                               Foreground="#FF69B4" FontSize="10" HorizontalAlignment="Right" IsHitTestVisible="False"/>
                                                </Grid>
                                            </StackPanel>

                                            <!-- Session XP boost -->
                                            <StackPanel Grid.Column="2" Margin="6,0,0,0"
                                                        ToolTip="会话期间触发时的经验倍率加成">
                                                <TextBlock Text="会话经验加成" Foreground="#A0A0A0" FontSize="10"/>
                                                <Grid>
                                                    <Slider x:Name="SliderKeywordSessionMultiplier" Minimum="1.0" Maximum="3.0"
                                                            TickFrequency="0.1" IsSnapToTickEnabled="True"
                                                            ValueChanged="SliderKeywordSessionMultiplier_ValueChanged"/>
                                                    <TextBlock x:Name="TxtKeywordSessionMultiplier" Text="1.5倍"
                                                               Foreground="#FF69B4" FontSize="10" HorizontalAlignment="Right" IsHitTestVisible="False"/>
                                                </Grid>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Screen OCR -->
                                        <Border CornerRadius="6" Padding="8" Margin="0,0,0,8"
                                                Background="#1A1A2E" BorderBrush="#353550" BorderThickness="1">
                                            <StackPanel>
                                                <Grid>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="屏幕文本检测 (OCR)" Foreground="#C0C0C0" FontSize="12" FontWeight="SemiBold"/>
                                                        <Button x:Name="HelpBtnScreenOcr" Style="{StaticResource HelpButtonStyle}"
                                                                VerticalAlignment="Center" Margin="6,0,0,0" Tag="ScreenOcr" Panel.ZIndex="1"/>
                                                    </StackPanel>
                                                    <CheckBox x:Name="ChkScreenOcrEnabled" Style="{StaticResource ToggleStyle}"
                                                              HorizontalAlignment="Right" VerticalAlignment="Center"
                                                              Checked="ChkScreenOcrEnabled_Changed" Unchecked="ChkScreenOcrEnabled_Changed"/>
                                                </Grid>
                                                <TextBlock Text="使用 Windows OCR 扫描屏幕上的关键词"
                                                           Foreground="#808080" FontSize="10" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                                <CheckBox x:Name="ChkKeywordHighlightEnabled" Content="在屏幕上高亮匹配的关键词"
                                                          Foreground="#A0A0A0" FontSize="10" Margin="0,4,0,0"
                                                          IsChecked="True"
                                                          Checked="ChkKeywordHighlightEnabled_Changed"
                                                          Unchecked="ChkKeywordHighlightEnabled_Changed"
                                                          ToolTip="当 OCR 检测到关键词匹配时，在单词上显示发光覆盖层"/>
                                                <StackPanel x:Name="HighlightDurationPanel" Visibility="Collapsed" Margin="0,4,0,0">
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                        <TextBlock Text="高亮模式：" Foreground="#A0A0A0" FontSize="10" VerticalAlignment="Center"/>
                                                        <ComboBox x:Name="CmbOcrHighlightMode" Margin="6,0,0,0" MinWidth="110"
                                                                  Style="{StaticResource DarkComboBoxStyle}" FontSize="10"
                                                                  SelectionChanged="CmbOcrHighlightMode_SelectionChanged"
                                                                  ToolTip="全部匹配：每次扫描立即高亮所有关键词。随机子集：每次扫描随机选择一部分高亮。">
                                                            <ComboBoxItem Content="全部匹配"/>
                                                            <ComboBoxItem Content="随机子集"/>
                                                        </ComboBox>
                                                    </StackPanel>
                                                    <CheckBox x:Name="ChkHighlightVisibleInCapture" Content="在屏幕截取/直播中显示高亮"
                                                              Foreground="#A0A0A0" FontSize="10" Margin="0,2,0,4"
                                                              Checked="ChkHighlightVisibleInCapture_Changed"
                                                              Unchecked="ChkHighlightVisibleInCapture_Changed"
                                                              ToolTip="启用时，关键词高亮将在 OBS、Discord 和其他屏幕共享中可见。禁用时，高亮不会显示在捕获中，以避免 OCR 反馈循环。"/>
                                                    <TextBlock Text="高亮持续时间" Foreground="#A0A0A0" FontSize="10"/>
                                                    <Grid ToolTip="粉色高亮在屏幕上停留的时间（0.3 秒 - 5.0 秒）">
                                                        <Slider x:Name="SliderKeywordHighlightDuration" Minimum="0.3" Maximum="5.0"
                                                                TickFrequency="0.1" IsSnapToTickEnabled="True"
                                                                ValueChanged="SliderKeywordHighlightDuration_ValueChanged"/>
                                                        <TextBlock x:Name="TxtKeywordHighlightDuration" Text="0.6秒"
                                                                   Foreground="#FF69B4" FontSize="10" HorizontalAlignment="Right" IsHitTestVisible="False"/>
                                                    </Grid>
                                                </StackPanel>
                                                <StackPanel x:Name="ScreenOcrIntervalPanel" Visibility="Collapsed" Margin="0,6,0,0">
                                                    <TextBlock Text="扫描间隔" Foreground="#A0A0A0" FontSize="10"/>
                                                    <Grid ToolTip="扫描屏幕关键词的频率（数值越低响应越快但 CPU 占用更高）">
                                                        <Slider x:Name="SliderScreenOcrInterval" Minimum="2" Maximum="10"
                                                                TickFrequency="1" IsSnapToTickEnabled="True"
                                                                ValueChanged="SliderScreenOcrInterval_ValueChanged"/>
                                                        <TextBlock x:Name="TxtScreenOcrInterval" Text="3秒"
                                                                   Foreground="#FF69B4" FontSize="10" HorizontalAlignment="Right" IsHitTestVisible="False"/>
                                                    </Grid>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <!-- Trigger list -->
                                        <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto" Margin="0,4,0,0"
                                                      PreviewMouseWheel="InnerScrollViewer_PreviewMouseWheel">
                                            <StackPanel x:Name="KeywordTriggerListPanel"/>
                                        </ScrollViewer>

                                        <!-- Action buttons -->
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <Button Content="+ 添加触发" Background="#FF69B4" Foreground="White" FontWeight="Bold"
                                                    FontSize="11" Padding="12,6" BorderThickness="0" Cursor="Hand"
                                                    Click="BtnAddKeywordTrigger_Click"/>
                                            <Button Content="从触发模式导入" Background="#353550" Foreground="#A0A0A0"
                                                    FontSize="11" Padding="12,6" Margin="8,0,0,0" BorderThickness="0" Cursor="Hand"
                                                    Click="BtnImportFromCustomTriggers_Click"/>
                                        </StackPanel>
                                    </StackPanel>
