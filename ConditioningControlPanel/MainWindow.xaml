                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Help button + left flavour text -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="HelpBtnLeaderboard" Style="{StaticResource HelpButtonStyle}" VerticalAlignment="Center" Tag="Leaderboard"/>
                                <Border Background="#1888AACC" CornerRadius="8" Padding="12,8" Margin="10,0,0,0" BorderBrush="#3388AACC" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="谁是最漂亮的 Bimbo？~" FontStyle="Italic" FontSize="15" FontWeight="Bold"
                                                   Foreground="#9988AACC"/>
                                        <TextBlock Text="每个等级都很重要，每个任务都很重要~" FontStyle="Italic" FontSize="13" FontWeight="Bold"
                                                   Foreground="#6688AACC" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Big LEADERBOARD title with stroke effect + mode toggle -->
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
