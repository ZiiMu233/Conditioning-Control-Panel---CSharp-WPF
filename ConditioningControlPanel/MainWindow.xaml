                        <Ellipse Width="3" Height="3" Fill="#FF69B4" Opacity="0.35" Canvas.Left="600" Canvas.Top="50">
                            <Ellipse.RenderTransform><TranslateTransform x:Name="P4"/></Ellipse.RenderTransform>
