                        <Ellipse Width="4" Height="4" Fill="#9B59B6" Opacity="0.3" Canvas.Left="800" Canvas.Top="40">
                            <Ellipse.RenderTransform><TranslateTransform x:Name="P5"/></Ellipse.RenderTransform>
