                                                   ToolTip="文字尺寸（50% 到 300%）"/>
                                        <TextBlock x:Name="TxtBouncingTextSize" Grid.Column="1" Style="{StaticResource ValueLabel}" Text="100%"/>
                                    </Grid>
                                    <Slider x:Name="SliderBouncingTextSize" Minimum="50" Maximum="300" Value="100" 
                                            Margin="0,1" ValueChanged="SliderBouncingTextSize_Changed"
                                            ToolTip="文字尺寸（50%=小，100%=正常，300%=巨大）"/>
                                    
                                    <!-- XP Info -->
                                    <TextBlock Text="💰 每次弹跳 +10 经验！" 
                                               Foreground="#50C878" FontSize="12" 
                                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                    
                                    <!-- Edit Phrases -->
                                    <Button Content="✏ 编辑短语"
                                            Background="#40FFFFFF" Foreground="White"
                                            BorderThickness="0" Padding="10,5" Margin="0,10,0,0"
                                            Cursor="Hand" Click="BtnEditBouncingText_Click"
                                            ToolTip="自定义弹跳文字短语"/>

                                    <!-- Show Over Videos -->
                                    <Grid Margin="0,10,0,0">
                                        <TextBlock Text="覆盖视频显示" Style="{StaticResource SettingLabel}"
                                                   ToolTip="在全屏视频上保持弹跳文字可见"/>
                                        <CheckBox x:Name="ChkBouncingTextAlwaysOnTop" Style="{StaticResource ToggleStyle}"
                                                  HorizontalAlignment="Right"
                                                  Checked="ChkBouncingTextAlwaysOnTop_Changed" Unchecked="ChkBouncingTextAlwaysOnTop_Changed"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                            </Grid>
                            
                            <!-- Feature Image -->
                            <Rectangle x:Name="BouncingTextFeatureImage" Grid.Column="1" Style="{StaticResource RoundedFeatureImage}">
                                <Rectangle.Fill>
                                    <ImageBrush ImageSource="pack://application:,,,/Resources/features/bouncing_text.png" Stretch="UniformToFill"/>
                                </Rectangle.Fill>
                            </Rectangle>
                        </Grid>
                    </Border>

                    <!-- Brain Drain - DISABLED FOR REWORK -->
                    <Border Background="#1E1E3A" CornerRadius="8" Padding="12" Margin="0,5" Opacity="0.5"
                            ToolTip="此功能暂时禁用，我们正在改进性能。">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="💧 大脑排水" Foreground="#666666" FontWeight="Bold" FontSize="14"/>
                                        <TextBlock Text="🔧 重做中" Foreground="#FFA500" HorizontalAlignment="Right" FontSize="13" FontWeight="Bold"/>
                                    </Grid>
                                    <Border Background="#2A2A4A" CornerRadius="4" Padding="8" Margin="0,8,0,0">
                                        <TextBlock Text="正在重做 - 此功能暂时禁用，同时我们正在优化性能。请在未来更新中查看！"
                                                   Foreground="#FFA500" FontSize="11" TextWrapping="Wrap"/>
                                    </Border>
                                </StackPanel>

                                <!-- Hidden elements to prevent XAML binding errors -->
                                <StackPanel x:Name="BrainDrainLocked" Visibility="Collapsed"/>
                                <StackPanel x:Name="BrainDrainUnlocked" Visibility="Collapsed">
                                    <CheckBox x:Name="ChkBrainDrainEnabled" Visibility="Collapsed"/>
                                    <StackPanel x:Name="BrainDrainSettings" Visibility="Collapsed">
                                        <TextBlock x:Name="TxtBrainDrainIntensity"/>
                                        <Slider x:Name="SliderBrainDrainIntensity"/>
                                        <CheckBox x:Name="ChkBrainDrainHighRefresh"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <!-- Feature Image (grayed out) -->
                            <Rectangle x:Name="BrainDrainFeatureImage" Grid.Column="1" Style="{StaticResource RoundedFeatureImage}" Opacity="0.3">
                                <Rectangle.Fill>
                                    <ImageBrush ImageSource="pack://application:,,,/Resources/features/brain_drain.png" Stretch="UniformToFill"/>
                                </Rectangle.Fill>
                            </Rectangle>
                        </Grid>
                    </Border>

                    <!-- Mind Wipe - Lvl 75 -->
                    <Border Background="#1E1E3A" CornerRadius="8" Padding="12" Margin="0,5"
                            ToolTip="随机大脑擦除音频效果！在会话期间频率会增加。在75级解锁。">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0">
                            <!-- Locked State -->
                            <StackPanel x:Name="MindWipeLocked" Visibility="Visible">
                                <Grid>
                                    <TextBlock Text="🧠 大脑擦除" Foreground="#666666" FontWeight="Bold" FontSize="14"/>
                                    <TextBlock Text="🔒 等级 75" Foreground="#666666" HorizontalAlignment="Right" FontSize="13"/>
                                </Grid>
                                <TextBlock Text="达到等级 75 解锁" Foreground="{StaticResource PinkBrush}"
                                           FontSize="12" Margin="0,8,0,0"/>
                            </StackPanel>

                            <!-- Unlocked State -->
                            <StackPanel x:Name="MindWipeUnlocked" Visibility="Collapsed">
                                <Grid>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🧠 大脑擦除" Foreground="{StaticResource PinkBrush}" FontWeight="Bold" FontSize="14"/>
                                        <TextBlock Text="✔ 等级 75" Foreground="{StaticResource PinkBrush}" Margin="8,0,0,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="ChkMindWipeEnabled" Style="{StaticResource ToggleStyle}"
                                              HorizontalAlignment="Right"
                                              Checked="ChkMindWipeEnabled_Changed" Unchecked="ChkMindWipeEnabled_Changed"/>
                                </Grid>

                                <StackPanel x:Name="MindWipeSettings" Margin="0,10,0,0">
                                    <!-- Frequency -->
                                    <Grid Margin="0,3,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource SettingLabel}" Text="频率"
                                                   ToolTip="每小时次数（会话外）"/>
                                        <TextBlock x:Name="TxtMindWipeFreq" Grid.Column="1" Style="{StaticResource ValueLabel}" Text="6/小时"/>
                                    </Grid>
                                    <Slider x:Name="SliderMindWipeFreq" Minimum="1" Maximum="180" Value="6"
                                            Margin="0,1" ValueChanged="SliderMindWipeFreq_Changed"
                                            ToolTip="大脑擦除频率（1-180 次/小时）"/>

                                    <!-- Volume -->
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource SettingLabel}" Text="音量"
                                                   ToolTip="大脑擦除音频音量（独立于其他音频）"/>
                                        <TextBlock x:Name="TxtMindWipeVolume" Grid.Column="1" Style="{StaticResource ValueLabel}" Text="50%"/>
                                    </Grid>
                                    <Slider x:Name="SliderMindWipeVolume" Minimum="0" Maximum="100" Value="50"
                                            Margin="0,1" ValueChanged="SliderMindWipeVolume_Changed"
                                            ToolTip="音量级别（0-100%）"/>

                                    <!-- Loop Toggle -->
                                    <Grid Margin="0,10,0,0">
                                        <TextBlock Style="{StaticResource SettingLabel}" Text="🔁 后台循环"
                                                   ToolTip="连续循环播放单个音轨，而不是随机触发"/>
                                        <CheckBox x:Name="ChkMindWipeLoop" Style="{StaticResource ToggleStyle}"
                                                  HorizontalAlignment="Right"
                                                  Checked="ChkMindWipeLoop_Changed" Unchecked="ChkMindWipeLoop_Changed"/>
                                    </Grid>

                                    <!-- Test Button -->
                                    <Button Content="🔊 立即测试"
                                            Background="#40FFFFFF" Foreground="White"
                                            BorderThickness="0" Padding="10,5" Margin="0,10,0,0"
                                            Cursor="Hand" Click="BtnTestMindWipe_Click"
                                            ToolTip="现在播放一个大脑擦除声音"/>
                                </StackPanel>
                            </StackPanel>
                            </Grid>

                            <!-- Feature Image -->
                            <Rectangle x:Name="MindWipeFeatureImage" Grid.Column="1" Style="{StaticResource RoundedFeatureImage}">
                                <Rectangle.Fill>
                                    <ImageBrush ImageSource="pack://application:,,,/Resources/features/Mind_Wipers.png" Stretch="UniformToFill"/>
                                </Rectangle.Fill>
                            </Rectangle>
                        </Grid>
                    </Border>

                </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Right Column: Scheduler + Ramp + Community stacked -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <!-- Scheduler Box -->
                <Border x:Name="SchedulerPanel" Style="{StaticResource SectionPanel}" Margin="5">
                    <StackPanel>
                        <Grid>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="📅 计划任务" FontSize="14" Margin="0"/>
                            <Button x:Name="HelpBtnScheduler" Style="{StaticResource HelpButtonStyle}" HorizontalAlignment="Right" Tag="Scheduler"/>
                        </Grid>
                        
                        <!-- Enable -->
                        <Grid Margin="0,3">
                            <TextBlock Style="{StaticResource SettingLabel}" Text="启用" FontSize="12"/>
                            <CheckBox x:Name="ChkSchedulerEnabled" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right"/>
                        </Grid>
                        
                        <!-- Time Range -->
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtStartTime" Grid.Column="0" Text="16:00" Background="#1E1E3A"
                                     Foreground="White" BorderBrush="{StaticResource PinkBrush}"
                                     Padding="6,4" FontSize="12" TextAlignment="Center"
                                     Style="{StaticResource FocusGlowTextBox}"/>
                            <TextBlock Grid.Column="1" Text="→" Foreground="White" FontSize="12" Margin="5,0" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtEndTime" Grid.Column="2" Text="22:00" Background="#1E1E3A"
                                     Foreground="White" BorderBrush="{StaticResource PinkBrush}"
                                     Padding="6,4" FontSize="12" TextAlignment="Center"
                                     Style="{StaticResource FocusGlowTextBox}"/>
                        </Grid>
                        
                        <!-- Days -->
                        <WrapPanel Margin="0,3">
                            <CheckBox x:Name="ChkMon" Content="一" Foreground="White" Margin="0,0,6,0" IsChecked="True" FontSize="10"/>
                            <CheckBox x:Name="ChkTue" Content="二" Foreground="White" Margin="0,0,6,0" IsChecked="True" FontSize="10"/>
                            <CheckBox x:Name="ChkWed" Content="三" Foreground="White" Margin="0,0,6,0" IsChecked="True" FontSize="10"/>
                            <CheckBox x:Name="ChkThu" Content="四" Foreground="White" Margin="0,0,6,0" IsChecked="True" FontSize="10"/>
                            <CheckBox x:Name="ChkFri" Content="五" Foreground="White" Margin="0,0,6,0" IsChecked="True" FontSize="10"/>
                            <CheckBox x:Name="ChkSat" Content="六" Foreground="White" Margin="0,0,6,0" IsChecked="True" FontSize="10"/>
                            <CheckBox x:Name="ChkSun" Content="日" Foreground="White" Margin="0,0,0,0" IsChecked="True" FontSize="10"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>
                
                <!-- Intensity Ramp Box -->
                <Border x:Name="RampPanel" Style="{StaticResource SectionPanel}" Margin="5">
                    <StackPanel>
                        <Grid>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="⚡ 强度斜坡" FontSize="14" Margin="0"/>
                            <Button x:Name="HelpBtnRamp" Style="{StaticResource HelpButtonStyle}" HorizontalAlignment="Right" Tag="IntensityRamp"/>
                        </Grid>
                        
                        <!-- Enable Ramp -->
                        <Grid Margin="0,3">
                            <TextBlock Style="{StaticResource SettingLabel}" Text="启用" FontSize="12"/>
                            <CheckBox x:Name="ChkRampEnabled" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right"/>
                        </Grid>
                        
                        <!-- Duration -->
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource SettingLabel}" Text="时长" FontSize="11"/>
                            <Slider Grid.Column="1" x:Name="SliderRampDuration" Minimum="10" Maximum="180" Value="60" 
                                    Margin="5,0" ValueChanged="SliderRampDuration_Changed"/>
                            <TextBlock x:Name="TxtRampDuration" Grid.Column="2" Style="{StaticResource ValueLabel}" Text="60 分钟" FontSize="11"/>
                        </Grid>
                        
                        <!-- Multiplier -->
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource SettingLabel}" Text="倍率" FontSize="11"/>
                            <Slider Grid.Column="1" x:Name="SliderMultiplier" Minimum="1" Maximum="3" Value="1.5" 
                                    Margin="5,0" ValueChanged="SliderMultiplier_Changed"/>
                            <TextBlock x:Name="TxtMultiplier" Grid.Column="2" Style="{StaticResource ValueLabel}" Text="1.5倍" FontSize="11"/>
                        </Grid>
                        
                        <!-- End at Ramp -->
                        <Grid Margin="0,2">
                            <TextBlock Style="{StaticResource SettingLabel}" Text="结束时停止" FontSize="11"/>
                            <CheckBox x:Name="ChkEndAtRamp" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right"/>
                        </Grid>
                        
                        <!-- Ramp Links -->
                        <TextBlock Text="链接到斜坡" Foreground="{StaticResource PinkBrush}" FontSize="11" Margin="0,5,0,2"/>
                        <Border Background="#1E1E3A" CornerRadius="4" Padding="6,4">
                            <WrapPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,8,2">
                                    <CheckBox x:Name="ChkRampLinkFlash" Style="{StaticResource ToggleStyle}"/>
                                    <TextBlock Text="闪图" Foreground="#AAA" FontSize="10" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,8,2">
                                    <CheckBox x:Name="ChkRampLinkSpiral" Style="{StaticResource ToggleStyle}"/>
                                    <TextBlock Text="螺旋" Foreground="#AAA" FontSize="10" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,8,2">
                                    <CheckBox x:Name="ChkRampLinkPink" Style="{StaticResource ToggleStyle}"/>
                                    <TextBlock Text="粉色" Foreground="#AAA" FontSize="10" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,8,2">
                                    <CheckBox x:Name="ChkRampLinkMaster" Style="{StaticResource ToggleStyle}"/>
                                    <TextBlock Text="主音量" Foreground="#AAA" FontSize="10" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                    <CheckBox x:Name="ChkRampLinkSubAudio" Style="{StaticResource ToggleStyle}"/>
                                    <TextBlock Text="潜意识" Foreground="#AAA" FontSize="10" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </WrapPanel>
                        </Border>
                    </StackPanel>
                </Border>
                
                <!-- Community Discord -->
                <Border Style="{StaticResource SectionPanel}" Margin="5" Padding="10,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <TextBlock Text="💬 社区" Foreground="{StaticResource PinkBrush}"
                                       FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Button x:Name="HelpBtnCommunity" Style="{StaticResource HelpButtonStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Tag="Community"/>
                        </Grid>

                        <!-- Discord Join Button - rectangular -->
                        <Button x:Name="BtnDiscord" Grid.Row="1" Click="BtnDiscord_Click" Cursor="Hand"
                                ToolTip="点击加入我们的 Discord 服务器！">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="discordBorder" Background="#5865F2" CornerRadius="8" Padding="12,8">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Image Source="pack://application:,,,/Resources/discord.png"
                                                   Width="28" Height="28" Stretch="Uniform" VerticalAlignment="Center"/>
                                            <TextBlock Text="加入 Discord" Foreground="White" FontSize="13" FontWeight="Bold"
                                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="discordBorder" Property="Background" Value="#6C75F2"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Discord Rich Presence Toggle -->
                        <CheckBox x:Name="ChkDiscordRichPresence" Grid.Row="2"
                                  HorizontalAlignment="Center"
                                  Margin="0,8,0,2"
                                  Checked="ChkDiscordRichPresence_Changed"
                                  Unchecked="ChkDiscordRichPresence_Changed">
                            <CheckBox.ToolTip>
                                <ToolTip Background="#1E1E3A" BorderBrush="#FF69B4" BorderThickness="1" Padding="10">
                                    <StackPanel MaxWidth="280">
                                        <TextBlock Text="Discord Rich Presence" Foreground="#FF69B4" FontSize="12" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <TextBlock Foreground="#CCCCCC" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8">
                                            在您的 Discord 状态中显示“正在玩条件控制面板”，以及您当前的等级和会话时间。
                                        </TextBlock>
                                        <TextBlock Text="谁能看到这个？" Foreground="#9B59B6" FontSize="11" FontWeight="Bold" Margin="0,0,0,4"/>
                                        <TextBlock Foreground="#AAAAAA" FontSize="10" TextWrapping="Wrap">
                                            只有那些已经可以看到您 Discord 活动状态的人（朋友、服务器成员，取决于您的 Discord 隐私设置）。这不会发送通知，它只是像任何其他游戏一样更新您的“正在玩”状态。
                                        </TextBlock>
                                    </StackPanel>
                                </ToolTip>
                            </CheckBox.ToolTip>
                            <CheckBox.Template>
                                <ControlTemplate TargetType="CheckBox">
                                    <StackPanel Orientation="Horizontal" Cursor="Hand">
                                        <Border x:Name="checkBorder" Width="14" Height="14"
                                                Background="#353550" BorderBrush="#FF69B4" BorderThickness="1.5"
                                                CornerRadius="3" VerticalAlignment="Center">
                                            <TextBlock x:Name="checkMark" Text="✓" Foreground="#FF69B4"
                                                       FontSize="10" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Visibility="Collapsed" Margin="0,-1,0,0"/>
                                        </Border>
                                        <TextBlock Text="丰富状态" Foreground="#A0A0A0" FontSize="10"
                                                   VerticalAlignment="Center" Margin="5,0,0,0"/>
                                    </StackPanel>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                            <Setter TargetName="checkBorder" Property="Background" Value="#452545"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="checkBorder" Property="BorderBrush" Value="#FF85C1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </CheckBox.Template>
                        </CheckBox>
                    </Grid>
                </Border>

                <!-- App Info / Updates -->
                <Border Style="{StaticResource SectionPanel}" Margin="5" Padding="10,8">
                    <Grid>
                        <Button x:Name="HelpBtnAppInfo" Style="{StaticResource HelpButtonStyle}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,0,0" Tag="AppInfo"/>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="应用信息" Foreground="{StaticResource PinkBrush}"
                                       FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock x:Name="TxtVersion" Text="版本" Foreground="#888888"
                                   FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <Button x:Name="BtnCheckUpdates" Content="检查更新"
                                Click="BtnCheckUpdates_Click" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#252542"/>
                                    <Setter Property="Foreground" Value="#E0E0E0"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Padding" Value="16,8"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border" Background="{TemplateBinding Background}"
                                                        CornerRadius="6" Padding="{TemplateBinding Padding}"
                                                        BorderBrush="#404060" BorderThickness="1">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#353560"/>
                                                        <Setter TargetName="border" Property="BorderBrush" Value="#FF69B4"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
            </ScrollViewer>
            </Grid>
        </ContentControl>

        <!-- Quests Tab -->
        <ContentControl x:Name="QuestsTab" Grid.Row="4" Margin="10,5,10,10" Visibility="Collapsed" Template="{StaticResource AnimatedTabBackground}">
            <Grid>
            <Border Style="{StaticResource SectionPanel}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15">
                        <!-- Sub-tab Navigation -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <Button x:Name="BtnQuestSubDaily" Content="每日/每周"
                                    Style="{StaticResource TabButtonActive}"
                                    Click="BtnQuestSubDaily_Click" Width="120"/>
                            <Button x:Name="BtnQuestSubRoadmap" Content="BIMBO 日记"
                                    Style="{StaticResource TabButton}"
                                    Click="BtnQuestSubRoadmap_Click" Margin="10,0,0,0" Width="150"/>
                        </StackPanel>

                        <!-- Daily/Weekly Quests Panel -->
                        <StackPanel x:Name="DailyWeeklyPanel">
                            <!-- Season Title Banner -->
                            <Border Background="#1A1A2E" CornerRadius="12" Padding="20,14" Margin="0,0,0,18"
                                    BorderThickness="1" BorderBrush="#3D3D60">
                                <TextBlock x:Name="TxtSeasonTitle" Text="Mindless March"
                                           FontSize="28" FontWeight="ExtraBold" FontStyle="Italic"
                                           HorizontalAlignment="Center" TextAlignment="Center">
                                    <TextBlock.Foreground>
                                        <LinearGradientBrush x:Name="SeasonTitleBrush" StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop x:Name="SeasonGrad1" Color="#FF69B4" Offset="0.0"/>
                                            <GradientStop x:Name="SeasonGrad2" Color="#DA70D6" Offset="0.25"/>
                                            <GradientStop x:Name="SeasonGrad3" Color="#FF1493" Offset="0.5"/>
                                            <GradientStop x:Name="SeasonGrad4" Color="#DA70D6" Offset="0.75"/>
                                            <GradientStop x:Name="SeasonGrad5" Color="#FF69B4" Offset="1.0"/>
                                        </LinearGradientBrush>
                                    </TextBlock.Foreground>
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#FF69B4" BlurRadius="15" ShadowDepth="0" Opacity="0.6"/>
                                    </TextBlock.Effect>
                                    <TextBlock.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <!-- Shimmer: animate gradient start/end points -->
                                                    <PointAnimation Storyboard.TargetName="SeasonTitleBrush"
                                                                    Storyboard.TargetProperty="StartPoint"
                                                                    From="-1,0.5" To="1,0.5"
                                                                    Duration="0:0:3"/>
                                                    <PointAnimation Storyboard.TargetName="SeasonTitleBrush"
                                                                    Storyboard.TargetProperty="EndPoint"
                                                                    From="0,0.5" To="2,0.5"
                                                                    Duration="0:0:3"/>
                                                    <!-- Pulsing glow -->
                                                    <DoubleAnimation Storyboard.TargetName="TxtSeasonTitle"
                                                                     Storyboard.TargetProperty="(TextBlock.Effect).(DropShadowEffect.Opacity)"
                                                                     From="0.3" To="0.9"
                                                                     Duration="0:0:1.5"
                                                                     AutoReverse="True"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </TextBlock.Triggers>
                                </TextBlock>
                            </Border>

                            <!-- Header -->
                            <Grid Margin="0,0,0,20">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📜 任务" Foreground="#FF69B4" FontSize="18" FontWeight="Bold"/>
                                    <Button x:Name="HelpBtnQuests" Style="{StaticResource HelpButtonStyle}" Tag="Quests"/>
                                </StackPanel>
                                <TextBlock x:Name="TxtQuestStats" Text="本周已完成 0 个任务"
                                           Foreground="#888888" FontSize="12" HorizontalAlignment="Right"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Two-column layout for Daily and Weekly -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- DAILY QUEST CARD -->
                            <ContentControl Grid.Column="0" Style="{StaticResource AnimatedGradientPanel}"
                                    BorderThickness="2" BorderBrush="#FFD700">
                                <StackPanel>
                                    <!-- Card Header -->
                                    <Grid Margin="0,0,0,15">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="☀️" FontSize="20"/>
                                            <TextBlock Text="每日任务" Foreground="#FFD700"
                                                       FontSize="16" FontWeight="Bold" Margin="8,0,0,0"
                                                       VerticalAlignment="Center"/>
                                            <!-- Daily quest counter badge -->
                                            <Border x:Name="DailyQuestCounterBadge" Background="#3D3D60" CornerRadius="8"
                                                    Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Center">
                                                <TextBlock x:Name="TxtDailyQuestCounter" Text="0/3"
                                                           Foreground="#FFD700" FontSize="11" FontWeight="Bold"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="每日午夜重置" Foreground="#666666"
                                                   FontSize="10" HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                    </Grid>

                                    <!-- Daily Progress Segments -->
                                    <Grid Margin="0,8,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border x:Name="DailySegment1" Grid.Column="0" Background="#3D3D60"
                                                CornerRadius="3" Height="6"/>
                                        <Border x:Name="DailySegment2" Grid.Column="2" Background="#3D3D60"
                                                CornerRadius="3" Height="6"/>
                                        <Border x:Name="DailySegment3" Grid.Column="4" Background="#3D3D60"
                                                CornerRadius="3" Height="6"/>
                                    </Grid>
                                    <TextBlock Text="完成 3 个每日任务 · 1 个每周任务"
                                               Foreground="#666666" FontSize="10"
                                               HorizontalAlignment="Center" Margin="0,0,0,8"/>

                                    <!-- Quest Content -->
                                    <Border x:Name="DailyQuestCard" Background="#252542"
                                            CornerRadius="10" Padding="15" MinHeight="180">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock x:Name="TxtDailyQuestIcon" Text=""
                                                           FontSize="24" HorizontalAlignment="Left" Visibility="Collapsed"/>
                                                <TextBlock x:Name="TxtDailyQuestName" Text="加载中..."
                                                           Foreground="White" FontSize="16" FontWeight="Bold"
                                                           HorizontalAlignment="Left" Margin="0,0,0,5"/>
                                                <TextBlock x:Name="TxtDailyQuestDesc" Text=""
                                                           Foreground="#AAAAAA" FontSize="12"
                                                           HorizontalAlignment="Left" TextWrapping="Wrap"
                                                           MaxWidth="180"/>

                                                <!-- Progress Bar -->
                                                <Grid Margin="0,12,0,0">
                                                    <Border x:Name="DailyProgressTrack" Background="#1A1A2E" CornerRadius="4" Height="10">
                                                        <Border x:Name="DailyProgressFill" Background="#FFD700"
                                                                CornerRadius="4" HorizontalAlignment="Left" Width="0"/>
                                                    </Border>
                                                </Grid>
                                                <TextBlock x:Name="TxtDailyProgress" Text="0 / 0"
                                                           Foreground="#FFD700" FontSize="12" FontWeight="Bold"
                                                           HorizontalAlignment="Left" Margin="0,5,0,0"/>

                                                <!-- XP Reward -->
                                                <Border Background="#3D3D60" CornerRadius="5"
                                                        Padding="10,5" Margin="0,10,0,0"
                                                        HorizontalAlignment="Left">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock x:Name="TxtDailyXP" Text="🎁 0 经验"
                                                                   Foreground="#FF69B4" FontSize="14"
                                                                   FontWeight="Bold"/>
                                                        <TextBlock x:Name="TxtDailyStreakBonus" Text=""
                                                                   Foreground="#FFB347" FontSize="12"
                                                                   FontWeight="Bold" Margin="6,1,0,0"
                                                                   VerticalAlignment="Center"
                                                                   FontFamily="Segoe UI Emoji"
                                                                   Visibility="Collapsed"/>
                                                        <TextBlock x:Name="TxtDailyRerollBonus" Text=""
                                                                   Foreground="#7BC8F6" FontSize="12"
                                                                   FontWeight="Bold" Margin="6,1,0,0"
                                                                   VerticalAlignment="Center"
                                                                   Visibility="Collapsed"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                            <!-- Quest Image -->
                                            <Border Grid.Column="1" CornerRadius="12" Margin="10,0,0,0"
                                                    Width="150" Height="150" Background="#1A1A2E">
                                                <Border.Clip>
                                                    <RectangleGeometry RadiusX="12" RadiusY="12" Rect="0,0,150,150"/>
                                                </Border.Clip>
                                                <Grid>
                                                    <Image x:Name="ImgDailyQuest" Stretch="UniformToFill"/>
                                                    <!-- Checkmark overlay for completed state -->
                                                    <Border x:Name="DailyCompletedOverlay" Background="#802D4A2D"
                                                            Visibility="Collapsed">
                                                        <TextBlock Text="✓" Foreground="#00E676" FontSize="64"
                                                                   FontWeight="Bold" HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center">
                                                            <TextBlock.Effect>
                                                                <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2"/>
                                                            </TextBlock.Effect>
                                                        </TextBlock>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <!-- All Daily Quests Completed Message -->
                                    <Border x:Name="DailyAllCompletedMessage" Background="#2D4A2D" CornerRadius="10"
                                            Padding="15" MinHeight="180" Visibility="Collapsed">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="✅" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                            <TextBlock Text="所有每日任务已完成！" Foreground="#00E676"
                                                       FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"
                                                       Margin="0,0,0,5"/>
                                            <TextBlock Text="明天再来查看新任务" Foreground="#888888"
                                                       FontSize="12" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Reroll Button -->
                                    <Button x:Name="BtnRerollDaily" Content="🔄 重新随机"
                                            Style="{StaticResource OutlineButton}"
                                            Margin="0,15,0,0" Click="BtnRerollDaily_Click"
                                            ToolTip="重新随机一个不同的任务（每天一次）"/>
                                </StackPanel>
                            </ContentControl>

                            <!-- WEEKLY QUEST CARD -->
                            <ContentControl Grid.Column="2" Style="{StaticResource AnimatedGradientPanel}"
                                    BorderThickness="2" BorderBrush="#9370DB">
                                <StackPanel>
                                    <!-- Card Header -->
                                    <Grid Margin="0,0,0,15">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🌙" FontSize="20"/>
                                            <TextBlock Text="每周任务" Foreground="#9370DB"
                                                       FontSize="16" FontWeight="Bold" Margin="8,0,0,0"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="每周日重置" Foreground="#666666"
                                                   FontSize="10" HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                    <TextBlock Text="完成 1 个每周任务"
                                               Foreground="#666666" FontSize="10"
                                               HorizontalAlignment="Center" Margin="0,0,0,8"/>

                                    <!-- Quest Content -->
                                    <Border x:Name="WeeklyQuestCard" Background="#252542"
                                            CornerRadius="10" Padding="15" MinHeight="180">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock x:Name="TxtWeeklyQuestIcon" Text=""
                                                           FontSize="24" HorizontalAlignment="Left" Visibility="Collapsed"/>
                                                <TextBlock x:Name="TxtWeeklyQuestName" Text="加载中..."
                                                           Foreground="White" FontSize="16" FontWeight="Bold"
                                                           HorizontalAlignment="Left" Margin="0,0,0,5"/>
                                                <TextBlock x:Name="TxtWeeklyQuestDesc" Text=""
                                                           Foreground="#AAAAAA" FontSize="12"
                                                           HorizontalAlignment="Left" TextWrapping="Wrap"
                                                           MaxWidth="180"/>

                                                <!-- Progress Bar -->
                                                <Grid Margin="0,12,0,0">
                                                    <Border x:Name="WeeklyProgressTrack" Background="#1A1A2E" CornerRadius="4" Height="10">
                                                        <Border x:Name="WeeklyProgressFill" Background="#9370DB"
                                                                CornerRadius="4" HorizontalAlignment="Left" Width="0"/>
                                                    </Border>
                                                </Grid>
                                                <TextBlock x:Name="TxtWeeklyProgress" Text="0 / 0"
                                                           Foreground="#9370DB" FontSize="12" FontWeight="Bold"
                                                           HorizontalAlignment="Left" Margin="0,5,0,0"/>

                                                <!-- XP Reward -->
                                                <Border Background="#3D3D60" CornerRadius="5"
                                                        Padding="10,5" Margin="0,10,0,0"
                                                        HorizontalAlignment="Left">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock x:Name="TxtWeeklyXP" Text="🎁 0 经验"
                                                                   Foreground="#FF69B4" FontSize="14"
                                                                   FontWeight="Bold"/>
                                                        <TextBlock x:Name="TxtWeeklyStreakBonus" Text=""
                                                                   Foreground="#FFB347" FontSize="12"
                                                                   FontWeight="Bold" Margin="6,1,0,0"
                                                                   VerticalAlignment="Center"
                                                                   FontFamily="Segoe UI Emoji"
                                                                   Visibility="Collapsed"/>
                                                        <TextBlock x:Name="TxtWeeklyRerollBonus" Text=""
                                                                   Foreground="#7BC8F6" FontSize="12"
                                                                   FontWeight="Bold" Margin="6,1,0,0"
                                                                   VerticalAlignment="Center"
                                                                   Visibility="Collapsed"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                            <!-- Quest Image -->
                                            <Border Grid.Column="1" CornerRadius="12" Margin="10,0,0,0"
                                                    Width="150" Height="150" Background="#1A1A2E">
                                                <Border.Clip>
                                                    <RectangleGeometry RadiusX="12" RadiusY="12" Rect="0,0,150,150"/>
                                                </Border.Clip>
                                                <Grid>
                                                    <Image x:Name="ImgWeeklyQuest" Stretch="UniformToFill"/>
                                                    <!-- Checkmark overlay for completed state -->
                                                    <Border x:Name="WeeklyCompletedOverlay" Background="#802D4A2D"
                                                            Visibility="Collapsed">
                                                        <TextBlock Text="✓" Foreground="#00E676" FontSize="64"
                                                                   FontWeight="Bold" HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center">
                                                            <TextBlock.Effect>
                                                                <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2"/>
                                                            </TextBlock.Effect>
                                                        </TextBlock>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <!-- Reroll Button -->
                                    <Button x:Name="BtnRerollWeekly" Content="🔄 重新随机"
                                            Style="{StaticResource OutlineButton}"
                                            Margin="0,15,0,0" Click="BtnRerollWeekly_Click"
                                            ToolTip="重新随机一个不同的任务（每周一次）"/>
                                </StackPanel>
                            </ContentControl>
                        </Grid>

                            <!-- Quest Complete Banner (shown briefly when quest completes) -->
                            <Border x:Name="QuestCompleteBanner" Background="#2D4A2D" CornerRadius="10"
                                    Padding="15" Margin="0,20,0,0" Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="✨" FontSize="24"/>
                                    <TextBlock x:Name="TxtQuestComplete" Text="任务完成！"
                                               Foreground="#00E676" FontSize="18" FontWeight="Bold"
                                               Margin="10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="✨" FontSize="24"/>
                                </StackPanel>
                            </Border>

                            <!-- Quest Streak Calendar -->
                            <Border Background="#1A1A2E" CornerRadius="10" Padding="15,12" Margin="0,20,0,0">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="📅 任务连续" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TxtQuestStreakCount" Grid.Column="1" Text="" Foreground="#FFD700"
                                                   FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <Button x:Name="BtnFixStreak" Grid.Column="2" Content="🔧 修复日"
                                                Style="{StaticResource OutlineButton}" Padding="8,3" FontSize="11"
                                                Click="BtnFixStreak_Click" Visibility="Collapsed" VerticalAlignment="Center"/>
                                    </Grid>
                                    <Canvas x:Name="StreakCalendarCanvas" Height="50" ClipToBounds="True"
                                           SizeChanged="StreakCalendarCanvas_SizeChanged"/>
                                    <TextBlock x:Name="TxtFixStreakStatus" Text="" Foreground="#FF69B4" FontSize="11"
                                               TextAlignment="Center" Margin="0,5,0,0" Visibility="Collapsed"/>
                                </StackPanel>
                            </Border>

                            <!-- Quest Statistics Section -->
                            <Border Background="#1E1E3A" CornerRadius="10" Padding="15" Margin="0,20,0,0">
                                <StackPanel>
                                    <Grid Margin="0,0,0,15">
                                        <TextBlock Text="📊 任务统计" Foreground="White"
                                                   FontSize="14" FontWeight="Bold"/>
                                        <Button x:Name="HelpBtnQuestStats" Style="{StaticResource HelpButtonStyle}" HorizontalAlignment="Right" Tag="QuestStats"/>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                            <TextBlock x:Name="TxtTotalDailyCompleted" Text="0"
                                                       Foreground="#FFD700" FontSize="28" FontWeight="Bold"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="已完成每日" Foreground="#888888"
                                                       FontSize="11" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                            <TextBlock x:Name="TxtTotalWeeklyCompleted" Text="0"
                                                       Foreground="#9370DB" FontSize="28" FontWeight="Bold"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="已完成每周" Foreground="#888888"
                                                       FontSize="11" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                            <TextBlock x:Name="TxtTotalQuestXP" Text="0"
                                                       Foreground="#FF69B4" FontSize="28" FontWeight="Bold"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="总经验获得" Foreground="#888888"
                                                       FontSize="11" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <!-- End Daily/Weekly Panel -->

                        <!-- Bimbo Journal Panel -->
                        <StackPanel x:Name="RoadmapPanel" Visibility="Collapsed">
                            <!-- Journal Header -->
                            <TextBlock Text="看看你已经走了多远，亲爱的……"
                                       FontSize="26" FontStyle="Italic" FontWeight="Light"
                                       Foreground="#CC88AACC" HorizontalAlignment="Center"
                                       Margin="0,0,0,8" TextAlignment="Center"/>

                            <!-- Journal Info Box -->
                            <Border Background="#30FFD700" BorderBrush="#AAFFD700" BorderThickness="1.5"
                                    CornerRadius="6" Padding="14,10" Margin="20,0,20,14" MaxWidth="700"
                                    HorizontalAlignment="Center">
                                <StackPanel>
                                    <TextBlock Text="📸 Bimbo 日记是什么？" Foreground="#FFD700" FontSize="14" FontWeight="Bold" Margin="0,0,0,6"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="#DDFFFFFF" FontSize="12" LineHeight="18">
                                        <Run Text="每个轨道都有步骤，要求你拍照作为进度证明。"/>
                                        <LineBreak/>
                                        <Run Text="点击一个步骤，拍照并上传，即可标记完成并解锁下一个步骤。"/>
                                        <LineBreak/>
                                        <Run Text="完成一个轨道的所有步骤，即可解锁下一阶段的转变。"/>
                                    </TextBlock>
                                    <TextBlock Foreground="#AAFFD700" FontSize="11" FontStyle="Italic" Margin="0,8,0,0"
                                               Text="所有照片仅存储在您的电脑本地 - 不会上传或分享给任何人。"/>
                                </StackPanel>
                            </Border>

                            <!-- Track Selector Tabs -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                <Button x:Name="BtnTrack1" Content="空虚的玩偶"
                                        Style="{StaticResource TabButtonActive}"
                                        Click="BtnTrack_Click" Tag="EmptyDoll" Width="130"/>
                                <Button x:Name="BtnTrack2" Content="顺从的木偶"
                                        Style="{StaticResource TabButton}"
                                        Click="BtnTrack_Click" Tag="ObedientPuppet" Margin="10,0,0,0" Width="150"/>
                                <Button x:Name="BtnTrack3" Content="淫荡的吹气娃娃"
                                        Style="{StaticResource TabButton}"
                                        Click="BtnTrack_Click" Tag="SluttyBlowdoll" Margin="10,0,0,0" Width="150"/>
                            </StackPanel>

                            <!-- Track Info Header -->
                            <Border Background="#1E1E3A" CornerRadius="10" Padding="15" Margin="0,0,0,15">
                                <Grid>
                                    <Button x:Name="HelpBtnRoadmap" Style="{StaticResource HelpButtonStyle}" HorizontalAlignment="Right" VerticalAlignment="Top" Tag="Roadmap"/>
                                    <StackPanel>
                                        <TextBlock x:Name="TxtRoadmapTrackName" Text="空虚的玩偶"
                                                   Foreground="#FF69B4" FontSize="20" FontWeight="Bold"/>
                                        <TextBlock x:Name="TxtRoadmapTrackSubtitle" Text="初始阶段"
                                                   Foreground="#888888" FontSize="14"/>
                                        <TextBlock x:Name="TxtRoadmapTrackProgress" Text="0 / 7 个步骤已完成"
                                                   Foreground="#AAAAAA" FontSize="12" Margin="0,5,0,0"/>
                                    </StackPanel>
                                    <!-- Badge indicator for final track -->
                                    <StackPanel x:Name="BadgeIndicator" Orientation="Horizontal"
                                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                                Visibility="Collapsed">
                                        <TextBlock Text="🏆" FontSize="24"/>
                                        <TextBlock Text="已获得徽章！" Foreground="#FFD700" FontSize="14"
                                                   FontWeight="Bold" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Locked Track Overlay -->
                            <Border x:Name="TrackLockedOverlay" Background="#CC1A1A2E" CornerRadius="10"
                                    Padding="40" Visibility="Collapsed">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="🔒" FontSize="48" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TxtLockReason" Text="完成上一个轨道以解锁"
                                               Foreground="White" FontSize="16" Margin="0,15,0,0"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Horizontal Scrolling Roadmap -->
                            <ContentControl x:Name="RoadmapScrollContainer" Style="{StaticResource AnimatedGradientPanelWide}"
                                    MinHeight="220">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                              PreviewMouseWheel="HorizontalScrollViewer_PreviewMouseWheel">
                                    <StackPanel x:Name="RoadmapNodesPanel" Orientation="Horizontal" Margin="10,15"/>
                                </ScrollViewer>
                            </ContentControl>

                            <!-- Roadmap Statistics -->
                            <Border Background="#1E1E3A" CornerRadius="10" Padding="15" Margin="0,15,0,0">
                                <StackPanel>
                                    <Grid Margin="0,0,0,15">
                                        <TextBlock Text="📊 转变进度" Foreground="White"
                                                   FontSize="14" FontWeight="Bold"/>
                                        <Button x:Name="HelpBtnRoadmapStats" Style="{StaticResource HelpButtonStyle}" HorizontalAlignment="Right" Tag="RoadmapStats"/>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                            <TextBlock x:Name="TxtRoadmapTotalSteps" Text="0 / 21"
                                                       Foreground="#FF69B4" FontSize="24" FontWeight="Bold"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="步骤已完成" Foreground="#888888"
                                                       FontSize="11" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                            <TextBlock x:Name="TxtRoadmapPhotos" Text="0"
                                                       Foreground="#9370DB" FontSize="24" FontWeight="Bold"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="照片已提交" Foreground="#888888"
                                                       FontSize="11" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                            <TextBlock x:Name="TxtRoadmapJourneyDays" Text="--"
                                                       Foreground="#FFD700" FontSize="24" FontWeight="Bold"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="旅程天数" Foreground="#888888"
                                                       FontSize="11" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <!-- End Roadmap Panel -->
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Login Required Overlay -->
            <Border x:Name="QuestsLoginOverlay" Background="#E6151528" CornerRadius="12" Visibility="Collapsed">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="40">
                    <TextBlock Text="🔒" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <TextBlock Text="需要登录" Foreground="#FF69B4" FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="使用 Discord 或 Patreon 登录以访问任务和连续记录！"
                               Foreground="#AA99AA" FontSize="14" HorizontalAlignment="Center"
                               TextAlignment="Center" TextWrapping="Wrap" MaxWidth="350"/>
                </StackPanel>
            </Border>
            </Grid>
        </ContentControl>

        <!-- Achievements Tab -->
        <ContentControl x:Name="AchievementsTab" Grid.Row="4" Margin="10,5,10,10" Visibility="Collapsed"
                Template="{StaticResource AnimatedTabBackground}">
            <Border Style="{StaticResource SectionPanel}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <TextBlock Style="{StaticResource SectionHeader}" Text="🏆 成就" Margin="0"/>
                        <Button x:Name="HelpBtnAchievements" Style="{StaticResource HelpButtonStyle}" HorizontalAlignment="Right" Tag="Achievements"/>
                    </Grid>
                    <TextBlock Text="完成挑战以解锁成就！未解锁的成就在获得前会模糊显示。" 
                               Foreground="#888888" FontSize="12" Margin="0,0,0,15"/>
                    
                    <!-- Achievement Grid (populated in code-behind) -->
                    <UniformGrid x:Name="AchievementGrid" Columns="7" Margin="0,5">
                    </UniformGrid>
                    
                    <TextBlock x:Name="TxtAchievementCount" Text="0 / 25 成就已解锁" Foreground="#888888" FontSize="14"
                               HorizontalAlignment="Center" Margin="0,15,0,0"/>
                </StackPanel>
            </ScrollViewer>
            </Border>
        </ContentControl>

        <!-- Companion Tab (v5.5 - Revamped with outlined sections) -->
        <ContentControl x:Name="CompanionTab" Grid.Row="4" Margin="10,5,10,10" Visibility="Collapsed" Template="{StaticResource AnimatedTabBackground}">
            <Border Style="{StaticResource SectionPanel}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15">

                        <!-- Tab Header -->
                        <Grid Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="伴侣" Foreground="White" FontSize="22" FontWeight="Bold">
                                    <TextBlock.Effect>
