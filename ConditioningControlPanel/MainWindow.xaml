                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>            <Border Grid.Column="2" Grid.Row="0" Grid.RowSpan="3" Style="{StaticResource SectionPanel}" BorderBrush="#5865F2" BorderThickness="1"><ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="10"><TextBlock Text="社区设置" Foreground="#5865F2" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/><Border Background="#1A1A2E" CornerRadius="8" Padding="15" Margin="0,0,0,12" BorderBrush="#5865F2" BorderThickness="1"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel VerticalAlignment="Center"><TextBlock x:Name="TxtDiscordTabStatus" Text="未连接" Foreground="White" FontSize="14" FontWeight="Bold"/><TextBlock x:Name="TxtDiscordTabInfo" Text="链接 Discord 以使用社区功能" Foreground="#808080" FontSize="11" Margin="0,2,0,0"/></StackPanel><Button x:Name="BtnDiscordTabLogin" Grid.Column="1" Content="登录" Background="#5865F2" Foreground="White" BorderThickness="0" Padding="15,8" FontWeight="Bold" FontSize="11" Cursor="Hand" Click="BtnDiscordTabLogin_Click"/></Grid></Border><Border Background="#1E1E3A" CornerRadius="6" Padding="12" Margin="0,0,0,8"><Grid><StackPanel><TextBlock Text="Discord Rich Presence" Foreground="White" FontSize="12" FontWeight="SemiBold"/><TextBlock Text="显示您的活动状态" Foreground="#808080" FontSize="10"/></StackPanel><CheckBox x:Name="ChkDiscordTabRichPresence" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Checked="ChkDiscordRichPresence_Changed" Unchecked="ChkDiscordRichPresence_Changed"/></Grid></Border><Border Background="#1E1E3A" CornerRadius="6" Padding="12" Margin="0,0,0,8"><Grid><StackPanel><TextBlock Text="状态中显示等级" Foreground="White" FontSize="12" FontWeight="SemiBold"/><TextBlock Text="显示您的等级" Foreground="#808080" FontSize="10"/></StackPanel><CheckBox x:Name="ChkDiscordTabShowLevel" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" IsChecked="True" Checked="ChkShowLevelInPresence_Changed" Unchecked="ChkShowLevelInPresence_Changed"/></Grid></Border><TextBlock Text="社区分享" Foreground="#5865F2" FontSize="13" FontWeight="Bold" Margin="0,12,0,10"/><Border Background="#1E1E3A" CornerRadius="6" Padding="12" Margin="0,0,0,8"><Grid><StackPanel><TextBlock Text="分享成就" Foreground="White" FontSize="12" FontWeight="SemiBold"/><TextBlock Text="将成就发布到 Discord" Foreground="#808080" FontSize="10"/></StackPanel><CheckBox x:Name="ChkDiscordTabShareAchievements" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Checked="ChkShareAchievements_Changed" Unchecked="ChkShareAchievements_Changed"/></Grid></Border><Border Background="#1E1E3A" CornerRadius="6" Padding="12" Margin="0,0,0,8"><Grid><StackPanel><TextBlock Text="分享等级里程碑" Foreground="White" FontSize="12" FontWeight="SemiBold"/><TextBlock Text="将升级发布到 Discord" Foreground="#808080" FontSize="10"/></StackPanel><CheckBox x:Name="ChkDiscordTabShareLevelUps" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Checked="ChkShareLevelUps_Changed" Unchecked="ChkShareLevelUps_Changed"/></Grid></Border><Border Background="#1E1E3A" CornerRadius="6" Padding="12" Margin="0,0,0,8"><Grid><StackPanel><TextBlock Text="允许来自排行榜的私信" Foreground="White" FontSize="12" FontWeight="SemiBold"/><TextBlock Text="允许他人给您发消息" Foreground="#808080" FontSize="10"/></StackPanel><CheckBox x:Name="ChkDiscordTabAllowDm" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Checked="ChkAllowDiscordDm_Changed" Unchecked="ChkAllowDiscordDm_Changed"/></Grid></Border><Border Background="#1E1E3A" CornerRadius="6" Padding="12" Margin="0,0,0,8"><Grid><StackPanel><TextBlock Text="分享头像" Foreground="White" FontSize="12" FontWeight="SemiBold"/><TextBlock Text="向他人显示您的头像" Foreground="#808080" FontSize="10"/></StackPanel><CheckBox x:Name="ChkDiscordTabSharePfp" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Checked="ChkShareProfilePicture_Changed" Unchecked="ChkShareProfilePicture_Changed"/></Grid></Border><Border Background="#1E1E3A" CornerRadius="6" Padding="12" Margin="0,0,0,8"><Grid><StackPanel><TextBlock Text="显示在线状态" Foreground="White" FontSize="12" FontWeight="SemiBold"/><TextBlock Text="禁用后显示离线" Foreground="#808080" FontSize="10"/></StackPanel><CheckBox x:Name="ChkDiscordTabShowOnline" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" IsChecked="True" Checked="ChkShowOnlineStatus_Changed" Unchecked="ChkShowOnlineStatus_Changed"/></Grid></Border><TextBlock Text="所有分享均为可选。" Foreground="#5865F2" FontSize="10" FontStyle="Italic" Margin="0,10,0,0"/><Button Content="加入 Discord 服务器" Background="#5865F2" Foreground="White" BorderThickness="0" Padding="15,12" Margin="0,15,0,0" FontWeight="Bold" FontSize="12" Cursor="Hand" Click="BtnDiscord_Click"/></StackPanel></ScrollViewer></Border>
            </Grid>
        </ContentControl>
        <!-- Lab Tab -->
        <ContentControl x:Name="LabTab" Grid.Row="4" Margin="10,5,10,10" Visibility="Collapsed" Template="{StaticResource AnimatedTabBackground}">
            <Grid>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20">
                    <!-- Header -->
                    <TextBlock Text="实验室" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,0,0,4">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#00FF88" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text="实验性功能和特殊模式" Foreground="#666680" FontSize="12" Margin="0,0,0,16"/>

                    <!-- 2x2 Modes Grid -->
                    <UniformGrid Rows="2" Columns="2">
                        <!-- Lockdown Mode Card -->
                        <Border x:Name="LockdownCardBorder" CornerRadius="12" Margin="6" Padding="15">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1A1A32" Offset="0"/>
                                    <GradientStop Color="#201A38" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FF69B4" Offset="0"/>
                                    <GradientStop Color="#9B59B6" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.BorderThickness>
                                <Thickness>2</Thickness>
                            </Border.BorderThickness>
                            <StackPanel>
                                <Border x:Name="LockdownImageBorder" CornerRadius="10" Margin="0,0,0,12"
                                        BorderThickness="2" ClipToBounds="True">
                                    <Border.Background>
                                        <SolidColorBrush Color="#12FFFFFF"/>
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <SolidColorBrush x:Name="LockdownImageBorderBrush" Color="#FF1493"/>
                                    </Border.BorderBrush>
                                    <Border.Effect>
                                        <DropShadowEffect x:Name="LockdownImageGlow" Color="#FF1493" BlurRadius="12" ShadowDepth="0" Opacity="0.7"/>
                                    </Border.Effect>
                                    <Border.Triggers>
                                        <EventTrigger RoutedEvent="Border.Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                    <ColorAnimation Storyboard.TargetName="LockdownImageBorderBrush"
                                                                    Storyboard.TargetProperty="Color"
                                                                    From="#FF1493" To="#FF69B4" Duration="0:0:1.5"/>
                                                    <DoubleAnimation Storyboard.TargetName="LockdownImageGlow"
                                                                     Storyboard.TargetProperty="BlurRadius"
                                                                     From="12" To="22" Duration="0:0:1.5"/>
                                                    <DoubleAnimation Storyboard.TargetName="LockdownImageGlow"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     From="0.7" To="1.0" Duration="0:0:1.5"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Border.Triggers>
                                    <Image Source="Resources/lockdown_icon.png" Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>
                                <TextBlock Text="封锁模式" Foreground="White" FontWeight="Bold" FontSize="16" Margin="0,0,0,6"/>
                                <TextBlock Text="将自己锁定在一个定时调节会话中。时间结束前无法退出。"
                                           Foreground="#808090" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"/>

                                <!-- Setup Panel (visible when lockdown is NOT active) -->
                                <StackPanel x:Name="LockdownSetupPanel">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <TextBlock Text="时长：" Foreground="#808090" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <ComboBox x:Name="CmbLockdownDuration" Width="120" SelectedIndex="1"
                                                  Background="#1A1A2E" Foreground="Black" FontSize="12" BorderBrush="#404060">
                                            <ComboBoxItem Content="5 分钟" Tag="5" Foreground="Black"/>
                                            <ComboBoxItem Content="10 分钟" Tag="10" Foreground="Black"/>
                                            <ComboBoxItem Content="15 分钟" Tag="15" Foreground="Black"/>
                                            <ComboBoxItem Content="30 分钟" Tag="30" Foreground="Black"/>
                                            <ComboBoxItem Content="60 分钟" Tag="60" Foreground="Black"/>
                                            <ComboBoxItem Content="2 小时" Tag="120" Foreground="Black"/>
                                            <ComboBoxItem Content="4 小时" Tag="240" Foreground="Black"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <Button x:Name="BtnActivateLockdown" Content="激活" Cursor="Hand"
                                            Background="#FF69B4" Foreground="White" FontWeight="Bold" FontSize="12"
                                            BorderThickness="0" Padding="12,8" HorizontalAlignment="Left"
                                            Click="BtnActivateLockdown_Click">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="8"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </StackPanel>

                                <!-- Active Panel (visible when lockdown IS active) -->
                                <StackPanel x:Name="LockdownActivePanel" Visibility="Collapsed">
                                    <TextBlock Text="封锁激活" Foreground="#DC143C" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
                                    <TextBlock x:Name="TxtLockdownTimer" Text="00:00" Foreground="#DC143C" FontWeight="Bold" FontSize="28"
