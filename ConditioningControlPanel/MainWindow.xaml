                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsVisible" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard x:Name="WideAnimationStoryboard">
                                        <Storyboard RepeatBehavior="Forever">
